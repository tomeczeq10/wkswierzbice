# Uwaga (deploy przez `deploy/wks/docker-compose.yml`):
# `DATABASE_URL` i `UPLOADS_DIR` są ustawiane w `docker-compose.yml` (mount `./persist` → `/data/wks`).
# Poniższe wartości są typowe dla lokalnego `next dev` w `apps/cms`:
DATABASE_URL=file:./cms.db

# Wygeneruj: openssl rand -hex 32
PAYLOAD_SECRET=REPLACE_ME

# Lokalnie: względem `apps/cms`. W dockerze: nadpisywane przez compose.
UPLOADS_DIR=./media

# (opcjonalnie) cron sync sezonu
ENABLE_SEASON_CRON=false
# SEASON_CRON_SCHEDULE=0 6 * * *

# (opcjonalnie) seed-admin — przy `npm run seed:cms-on-server` pusty / admin@wks.local
# jest zamieniany na admin@wkswierzbice.pl; lokalnie w apps/cms/.env możesz zostawić wks.local.
ADMIN_EMAIL=admin@wkswierzbice.pl
ADMIN_PASSWORD=admin
