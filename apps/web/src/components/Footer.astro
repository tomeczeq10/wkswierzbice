---
import Logo from "./Logo.astro";
import { fetchSiteConfig } from "@/lib/cms-site";

const cfg = await fetchSiteConfig();
const SITE = cfg.site;
const CONTACT = cfg.contact;
const SOCIAL = cfg.social;
const NAV = cfg.nav;

const year = new Date().getFullYear();
---

<footer class="bg-brand-ink text-slate-300">

  <!-- CTA strip -->
  <div class="bg-brand-primary">
    <div class="container mx-auto py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-white">
      <div>
        <div class="font-display text-2xl uppercase">Zostań częścią WKS-u</div>
        <p class="text-sm text-white/80 mt-1">Nabory otwarte · Treningi dla wszystkich grup wiekowych</p>
      </div>
      <div class="flex gap-3 shrink-0">
        <a href="/nabory" class="btn-secondary text-sm">Zapisz dziecko</a>
        <a href="/kontakt" class="btn-outline text-white text-sm">Skontaktuj się</a>
      </div>
    </div>
  </div>

  <!-- Main footer grid -->
  <div class="container mx-auto py-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

    <!-- Brand -->
    <div>
      <div class="flex items-center gap-3 text-white">
        <Logo variant="light" class="h-12 w-12" />
        <div>
          <div class="font-display text-xl uppercase">{SITE.shortName}</div>
          <div class="text-xs text-white/50">od {SITE.founded} roku</div>
        </div>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-slate-400">{SITE.tagline}</p>
      <div class="mt-5 flex gap-2">
        {SOCIAL.facebook && (
          <a href={SOCIAL.facebook} aria-label="Facebook" class="w-9 h-9 rounded-lg bg-white/5 hover:bg-brand-primary transition-colors flex items-center justify-center" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.7-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12"/></svg>
          </a>
        )}
        {SOCIAL.instagram && (
          <a href={SOCIAL.instagram} aria-label="Instagram" class="w-9 h-9 rounded-lg bg-white/5 hover:bg-brand-primary transition-colors flex items-center justify-center" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.9.9 1.4.2.5.3 1.1.4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.1-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.9.7-1.4.9-.5.2-1.1.3-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.1-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.9-.9-1.4-.2-.5-.3-1.1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.1.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.9-.7 1.4-.9.5-.2 1.1-.3 2.2-.4C8.4 2.2 8.8 2.2 12 2.2m0 1.6c-3.1 0-3.5 0-4.7.1-1 .1-1.6.2-2 .3-.5.2-.8.4-1.2.8-.4.4-.6.7-.8 1.2-.1.4-.3 1-.3 2-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c.1 1 .2 1.6.3 2 .2.5.4.8.8 1.2.4.4.7.6 1.2.8.4.1 1 .3 2 .3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1-.1 1.6-.2 2-.3.5-.2.8-.4 1.2-.8.4-.4.6-.7.8-1.2.1-.4.3-1 .3-2 .1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c-.1-1-.2-1.6-.3-2-.2-.5-.4-.8-.8-1.2-.4-.4-.7-.6-1.2-.8-.4-.1-1-.3-2-.3-1.2-.1-1.6-.1-4.7-.1m0 2.7a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11m0 1.8a3.7 3.7 0 1 0 0 7.4 3.7 3.7 0 0 0 0-7.4m5.7-2a1.3 1.3 0 1 1 0 2.6 1.3 1.3 0 0 1 0-2.6"/></svg>
          </a>
        )}
        {SOCIAL.youtube && (
          <a href={SOCIAL.youtube} aria-label="YouTube" class="w-9 h-9 rounded-lg bg-white/5 hover:bg-brand-primary transition-colors flex items-center justify-center" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2c-.3-1-1-1.8-2-2C19.6 3.8 12 3.8 12 3.8s-7.6 0-9.5.4c-1 .2-1.7 1-2 2C0 8.1 0 12 0 12s0 3.9.5 5.8c.3 1 1 1.8 2 2 1.9.5 9.5.5 9.5.5s7.6 0 9.5-.5c1-.2 1.7-1 2-2 .5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8M9.6 15.6V8.4l6.4 3.6-6.4 3.6"/></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Nav -->
    <div>
      <h4 class="text-white text-xs font-display uppercase tracking-[0.2em] mb-5">Nawigacja</h4>
      <ul class="space-y-2.5 text-sm">
        {NAV.map(({ label, href }) => (
          <li>
            <a href={href} class="text-slate-400 hover:text-white transition-colors flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-brand-primary inline-block shrink-0"></span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Kontakt -->
    <div>
      <h4 class="text-white text-xs font-display uppercase tracking-[0.2em] mb-5">Kontakt</h4>
      <address class="not-italic text-sm space-y-3 text-slate-400">
        <div class="flex gap-3 items-start">
          <svg class="w-4 h-4 mt-0.5 text-brand-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <p>{CONTACT.address.street}</p>
            <p>{CONTACT.address.postalCode} {CONTACT.address.city}</p>
          </div>
        </div>
        <div class="flex gap-3 items-center">
          <svg class="w-4 h-4 text-brand-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.88-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href={`tel:${CONTACT.phone.replace(/\s+/g, "")}`} class="hover:text-white transition-colors">{CONTACT.phone}</a>
        </div>
        <div class="flex gap-3 items-center">
          <svg class="w-4 h-4 text-brand-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href={`mailto:${CONTACT.email}`} class="hover:text-white transition-colors">{CONTACT.email}</a>
        </div>
      </address>
    </div>

    <!-- Facebook follower count + sponsor CTA -->
    <div>
      <h4 class="text-white text-xs font-display uppercase tracking-[0.2em] mb-5">Społeczność</h4>
      {SOCIAL.facebook && (
        <a href={SOCIAL.facebook} target="_blank" rel="noopener"
          class="flex items-center gap-4 p-4 rounded-xl bg-white/5 hover:bg-brand-primary/30 transition-colors border border-white/10 group">
          <svg class="w-8 h-8 text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.7-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12"/></svg>
          <div>
            <div class="font-display text-white text-lg leading-tight">{SOCIAL.facebookFollowers.toLocaleString("pl-PL")}</div>
            <div class="text-xs text-slate-400">obserwujących na FB</div>
          </div>
        </a>
      )}
      <div class="mt-5 p-4 rounded-xl bg-white/5 border border-white/10">
        <div class="text-xs text-slate-400 mb-2">Zostań sponsorem</div>
        <p class="text-sm text-slate-300">Skontaktuj się z zarządem klubu</p>
        <a href={`mailto:${CONTACT.email}`} class="mt-2 inline-block text-xs text-brand-secondary hover:underline font-display uppercase tracking-wide">
          {CONTACT.email} →
        </a>
      </div>
    </div>

  </div>

  <div class="border-t border-white/10">
    <div class="container mx-auto py-5 flex flex-col sm:flex-row gap-2 items-center justify-between text-xs text-slate-500">
      <p>© {year} {SITE.name}. Wszelkie prawa zastrzeżone.</p>
      <div class="flex gap-4">
        <a href="/polityka-prywatnosci" class="hover:text-slate-300 transition-colors">Polityka prywatności</a>
        <a href="/kontakt" class="hover:text-slate-300 transition-colors">Kontakt</a>
      </div>
    </div>
  </div>
</footer>
