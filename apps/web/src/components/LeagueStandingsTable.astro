---
import type { SeasonData } from "@/lib/cms-season";

type StandingRow = SeasonData["standings"][number];

interface Props {
  standings: StandingRow[];
  seasonLabel: string;
  /** Domyślnie WKS Wierzbice — wiersz wyróżniony w tabeli. */
  highlightTeam?: string;
}

const { standings, seasonLabel, highlightTeam = "WKS Wierzbice" } = Astro.props;

const isHighlight = (name: string) => name?.trim() === highlightTeam;
const wksPosition = standings.find((s) => isHighlight(s.team))?.position ?? null;
---

{
  standings.length > 0 && (
    <>
      <div class="text-center mb-10">
        <span class="section-kicker">{seasonLabel}</span>
        <h2 class="section-title">Aktualna tabela</h2>
        {wksPosition != null && (
          <p class="mt-3 text-slate-600 text-sm">
            {highlightTeam} zajmuje obecnie <strong>{wksPosition}. miejsce</strong> w tabeli.
          </p>
        )}
      </div>
      <div class="card p-0 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-brand-primary text-white font-display uppercase text-xs">
              <tr>
                <th class="text-left px-3 py-3 w-10">#</th>
                <th class="text-left px-3 py-3">Drużyna</th>
                <th class="text-center px-2 py-3">M</th>
                <th class="text-center px-2 py-3">Pkt</th>
                <th class="text-center px-2 py-3 hidden sm:table-cell">Z</th>
                <th class="text-center px-2 py-3 hidden sm:table-cell">R</th>
                <th class="text-center px-2 py-3 hidden sm:table-cell">P</th>
                <th class="text-center px-2 py-3">Bramki</th>
              </tr>
            </thead>
            <tbody>
              {standings.map((row) => {
                const highlight = isHighlight(row.team);
                return (
                  <tr
                    class:list={[
                      "border-b border-slate-100",
                      highlight
                        ? "bg-brand-accent/30 font-semibold text-brand-primary"
                        : "hover:bg-slate-50",
                    ]}
                  >
                    <td class="px-3 py-2 font-display">{row.position}.</td>
                    <td class="px-3 py-2">{row.team}</td>
                    <td class="px-2 py-2 text-center">{row.played}</td>
                    <td class="px-2 py-2 text-center font-display text-base">{row.points}</td>
                    <td class="px-2 py-2 text-center hidden sm:table-cell">{row.wins}</td>
                    <td class="px-2 py-2 text-center hidden sm:table-cell">{row.draws}</td>
                    <td class="px-2 py-2 text-center hidden sm:table-cell">{row.losses}</td>
                    <td class="px-2 py-2 text-center whitespace-nowrap">{row.goals}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </>
  )
}
