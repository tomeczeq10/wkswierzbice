---
/**
 * LiveBanner — slim sticky pill ponad layoutem strony.
 * Pokazuje 3 stany:
 *  - LIVE (state in live/ht/live2): "🔴 LIVE · WKS 1:0 Polonia · 23' · Oglądaj relację →"
 *  - PRE (enabled & state=pre): "📅 Dziś mecz: WKS vs Polonia · 15:00 · Oglądaj relację →"
 *  - WYŁĄCZONY: ukryty całkowicie (display: none).
 *
 * Klik prowadzi do /live (dedykowana strona realtime).
 * SSR ustawia stan początkowy. Inline script aktualizuje co 5s przez polling
 * /wks-live-match (lekki — tylko widoczność + minuta).
 */
import { fetchLiveMatch } from "@/lib/cms-live";

const live = await fetchLiveMatch();
const isLive = Boolean(
  live?.enabled && (live?.state === "live" || live?.state === "ht" || live?.state === "live2"),
);
const isPre = Boolean(live?.enabled && live?.state === "pre");
const visible = isLive || isPre;

function fmtKickoff(iso: string | undefined): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleTimeString("pl-PL", { hour: "2-digit", minute: "2-digit", timeZone: "Europe/Warsaw" });
}

const initialKickoff = fmtKickoff(live?.kickoffPlanned);
const initialClock = live?.clock?.time ?? "--:--";
---

<a
  href="/live"
  id="wks-live-banner"
  data-mode={isLive ? "live" : isPre ? "pre" : "off"}
  class:list={[
    "wks-live-banner",
    !visible && "is-hidden",
    isLive ? "is-live" : "is-pre",
  ]}
  aria-label="Otwórz relację na żywo"
>
  <span class="dot" aria-hidden="true"></span>
  <span class="label" data-banner-label>{isLive ? "LIVE" : "DZIŚ MECZ"}</span>
  <span class="text">
    <span data-banner-home>{live?.homeLabel ?? "WKS"}</span>
    {isLive ? (
      <>
        <span class="score" data-banner-score>{live?.scoreHome ?? 0}:{live?.scoreAway ?? 0}</span>
      </>
    ) : (
      <span class="vs">vs</span>
    )}
    <span data-banner-away>{live?.awayLabel ?? "—"}</span>
  </span>
  <span class="meta" data-banner-meta>
    {isLive ? initialClock : initialKickoff || ""}
  </span>
  <span class="cta">Oglądaj →</span>
</a>

<style>
  .wks-live-banner {
    display: flex;
    align-items: center;
    gap: 8px 12px;
    padding: 10px 14px;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    flex-wrap: wrap;
  }
  .wks-live-banner.is-hidden { display: none; }
  .wks-live-banner.is-live {
    background: linear-gradient(90deg, #dc2626 0%, #991b1b 100%);
  }
  .wks-live-banner.is-pre {
    background: linear-gradient(90deg, #166534 0%, #14532d 100%);
  }
  .wks-live-banner .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 99px;
    background: #fff;
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.18);
    flex-shrink: 0;
  }
  .wks-live-banner.is-live .dot {
    animation: wks-banner-pulse 1.5s ease-in-out infinite;
  }
  @keyframes wks-banner-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.25); opacity: 0.55; }
  }
  .wks-live-banner .label {
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.18);
    padding: 3px 8px;
    border-radius: 99px;
    flex-shrink: 0;
  }
  .wks-live-banner .text {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
  }
  .wks-live-banner .text > span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wks-live-banner .score {
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: #fff;
    background: rgba(255, 255, 255, 0.22);
    padding: 2px 8px;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .wks-live-banner .vs {
    opacity: 0.7;
    flex-shrink: 0;
  }
  .wks-live-banner .meta {
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    opacity: 0.92;
    flex-shrink: 0;
  }
  .wks-live-banner .cta {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.18);
    padding: 5px 12px;
    border-radius: 99px;
    flex-shrink: 0;
  }
  @media (max-width: 480px) {
    .wks-live-banner .text { font-size: 11px; }
    .wks-live-banner .label { font-size: 9px; }
    .wks-live-banner .cta { display: none; }
  }
</style>

<script is:inline>
  // Lekki polling co 5s — banner ma tylko świecić/zgasnąć i pokazywać aktualny wynik+minutę.
  // Pełne real-time + eventy są na /live (dedykowana strona).
  (() => {
    const banner = document.getElementById("wks-live-banner");
    if (!banner) return;
    const $home = banner.querySelector("[data-banner-home]");
    const $away = banner.querySelector("[data-banner-away]");
    const $score = banner.querySelector("[data-banner-score]");
    const $meta = banner.querySelector("[data-banner-meta]");
    const $label = banner.querySelector("[data-banner-label]");

    const stateLabel = (s) => {
      if (s === "live" || s === "live2" || s === "ht") return "LIVE";
      if (s === "pre") return "DZIŚ MECZ";
      return "";
    };

    const pad = (n) => String(n).padStart(2, "0");
    const parseMs = (iso) => {
      if (!iso) return null;
      const t = new Date(iso).getTime();
      return Number.isFinite(t) ? t : null;
    };
    const computeClock = (data) => {
      const status = data.state;
      const a1 = Math.max(0, Math.trunc(Number(data.addedTime1) || 0));
      const a2 = Math.max(0, Math.trunc(Number(data.addedTime2) || 0));
      if (status === "ht") return `${pad(45 + a1)}:00`;
      if (status === "ft") return `${pad(90 + a2)}:00`;
      const kickoff = parseMs(data.kickoffReal);
      if (!kickoff) return "--:--";
      const pause = parseMs(data.pauseAt);
      const resume = parseMs(data.resumeAt);
      const now = Date.now();
      if (status === "live") {
        const end = pause && (!resume || resume < pause) ? pause : now;
        const s = Math.max(0, Math.floor((end - kickoff) / 1000));
        return `${pad(Math.floor(s / 60))}:${pad(s % 60)}`;
      }
      if (status === "live2") {
        if (!resume) {
          const s = Math.max(0, Math.floor((now - kickoff) / 1000));
          return `${pad(Math.floor(s / 60))}:${pad(s % 60)}`;
        }
        const end = pause && pause > resume ? pause : now;
        const s = 45 * 60 + Math.max(0, Math.floor((end - resume) / 1000));
        return `${pad(Math.floor(s / 60))}:${pad(s % 60)}`;
      }
      return "--:--";
    };
    const fmtKickoff = (iso) => {
      try {
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return "";
        return d.toLocaleTimeString("pl-PL", { hour: "2-digit", minute: "2-digit", timeZone: "Europe/Warsaw" });
      } catch {
        return "";
      }
    };

    let live = null;
    let tickerHandle = null;

    const apply = (raw) => {
      // Normalize: SSE z CMS ma `status`, polling /wks-live-match ma `state`.
      const data = raw ? { ...raw, state: raw.state || raw.status } : null;
      const isLive = Boolean(
        data && data.enabled && (data.state === "live" || data.state === "ht" || data.state === "live2"),
      );
      const isPre = Boolean(data && data.enabled && data.state === "pre");
      const visible = isLive || isPre;
      banner.classList.toggle("is-hidden", !visible);
      banner.classList.toggle("is-live", isLive);
      banner.classList.toggle("is-pre", !isLive && isPre);
      banner.setAttribute("data-mode", isLive ? "live" : isPre ? "pre" : "off");
      if (!visible) {
        live = null;
        return;
      }
      live = data;
      if ($home) $home.textContent = data.homeLabel || "WKS";
      if ($away) $away.textContent = data.awayLabel || "—";
      if ($label) $label.textContent = stateLabel(data.state);
      if (isLive) {
        if ($score) {
          $score.textContent = `${data.scoreHome ?? 0}:${data.scoreAway ?? 0}`;
          $score.style.display = "";
        }
        if ($meta) $meta.textContent = computeClock(data);
      } else {
        // pre: no score, show kickoff time
        if ($score) $score.style.display = "none";
        if ($meta) $meta.textContent = fmtKickoff(data.kickoffPlanned) || "";
      }
    };

    // Tykanie zegara co sekundę gdy LIVE — bez czekania na poll/SSE.
    if (tickerHandle) clearInterval(tickerHandle);
    tickerHandle = setInterval(() => {
      if (!live) return;
      if (live.state === "live" || live.state === "live2") {
        if ($meta) $meta.textContent = computeClock(live);
      }
    }, 1000);

    let inFlight = false;
    const tick = async () => {
      if (inFlight) return;
      inFlight = true;
      try {
        const r = await fetch(`/wks-live-match?t=${Date.now()}`, { cache: "no-store" });
        if (!r.ok) return;
        const data = await r.json();
        apply(data);
      } catch {
      } finally {
        inFlight = false;
      }
    };
    tick();
    setInterval(tick, 5000);
  })();
</script>
