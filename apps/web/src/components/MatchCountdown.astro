---
interface Match {
  round: number;
  date: string | null;
  time: string | null;
  dateRaw: string | null;
  venue: "home" | "away";
  opponent: string;
}

interface Props {
  match: Match;
}

const { match } = Astro.props;

const isoDate = match.date
  ? `${match.date}T${match.time ?? "12:00"}:00+02:00`
  : null;

const venueLabel = match.venue === "home" ? "Mecz u siebie" : "Mecz wyjazdowy";
---

<section class="bg-brand-ink text-white py-10">
  <div class="container mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <div class="text-center md:text-left">
        <div class="text-xs uppercase tracking-[0.3em] text-brand-secondary mb-2 font-display">
          Najbliższy mecz · kolejka {match.round}
        </div>
        <div class="font-display text-3xl sm:text-4xl uppercase leading-tight">
          WKS Wierzbice
          <span class="text-white/40 text-2xl mx-2">vs</span>
          {match.opponent}
        </div>
        <div class="mt-2 text-sm text-white/60 flex flex-wrap gap-x-4 gap-y-1 justify-center md:justify-start">
          <span>{venueLabel}</span>
          {match.dateRaw && <span>{match.dateRaw}</span>}
        </div>
      </div>

      {isoDate ? (
        <div class="flex gap-3 sm:gap-4 text-center" id="countdown-wrap">
          {(["days", "hours", "minutes", "seconds"] as const).map((unit) => (
            <div class="flex flex-col items-center">
              <div
                id={`cd-${unit}`}
                class="w-16 sm:w-20 h-16 sm:h-20 bg-brand-primary-dark rounded-lg flex items-center justify-center font-display text-3xl sm:text-4xl"
              >
                --
              </div>
              <div class="mt-1.5 text-[10px] uppercase tracking-widest text-white/50">
                {unit === "days" ? "dni" : unit === "hours" ? "godz" : unit === "minutes" ? "min" : "sek"}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-white/50 text-sm font-display uppercase tracking-widest">
          Termin do ustalenia
        </div>
      )}

    </div>

    <div class="mt-6 flex gap-3 justify-center md:justify-start">
      <a href="/terminarz" class="btn-primary text-sm">Pełny terminarz</a>
    </div>
  </div>
</section>

{isoDate && (
  <script define:vars={{ isoDate }}>
    const target = new Date(isoDate).getTime();

    const pad = (n) => String(Math.max(0, n)).padStart(2, "0");

    function tick() {
      const now = Date.now();
      const diff = target - now;

      if (diff <= 0) {
        document.getElementById("countdown-wrap")?.remove();
        return;
      }

      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);

      const el = (id) => document.getElementById(id);
      el("cd-days") && (el("cd-days").textContent = pad(days));
      el("cd-hours") && (el("cd-hours").textContent = pad(hours));
      el("cd-minutes") && (el("cd-minutes").textContent = pad(minutes));
      el("cd-seconds") && (el("cd-seconds").textContent = pad(seconds));
    }

    tick();
    setInterval(tick, 1000);
  </script>
)}
