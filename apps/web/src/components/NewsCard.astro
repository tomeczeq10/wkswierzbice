---
import { formatDate } from "@/lib/format";
import { stripLeadingTitleFromExcerpt } from "@/lib/news-excerpt";

interface Props {
  href: string;
  title: string;
  date: Date | string;
  excerpt: string;
  cover?: string;
  coverAlt?: string;
  tags?: string[];
  facebookUrl?: string;
  showBadges?: boolean;
  coverBadges?: {
    label: string;
    variant: "red" | "blue" | "green" | "slate";
    href?: string;
    newTab?: boolean;
    icon?: "none" | "facebook" | "star" | "trophy";
  }[];
}

const {
  href,
  title,
  date,
  excerpt,
  cover,
  coverAlt = "",
  tags = [],
  facebookUrl,
  showBadges = false,
  coverBadges = [],
} = Astro.props;

const cardExcerpt = stripLeadingTitleFromExcerpt(title, excerpt);

const badgeClassByVariant: Record<string, string> = {
  red: "bg-brand-secondary text-white",
  blue: "bg-[#1877F2]/95 text-white",
  green: "bg-brand-primary text-white",
  slate: "bg-slate-900/90 text-white",
};
---

<article class="group flex flex-col overflow-hidden rounded-lg bg-white border border-slate-200 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
  <div class="relative block aspect-[4/3] overflow-hidden bg-slate-200">
    {cover ? (
      <img
        src={cover}
        alt={coverAlt}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.03] z-0"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-brand-primary to-brand-primary-dark flex items-center justify-center z-0">
        <svg class="w-16 h-16 text-white/20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" />
        </svg>
      </div>
    )}

    {
      showBadges && coverBadges.length > 0 && (
        <div class="absolute top-3 left-3 right-3 flex items-start justify-between gap-2 z-10">
          <div class="flex gap-1.5 flex-wrap">
            {coverBadges.slice(0, 3).map((b) => {
              const cls = badgeClassByVariant[b.variant] ?? badgeClassByVariant.red;
              const base =
                `inline-flex items-center gap-1.5 px-2 py-0.5 rounded uppercase tracking-wide text-[10px] font-display font-bold shadow-sm ${cls}`;

              const icon =
                b.icon === "facebook" ? (
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.57V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
                  </svg>
                ) : b.icon === "star" ? (
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                ) : b.icon === "trophy" ? (
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M7 4h10v2h3v2a5 5 0 0 1-5 5h-1a5 5 0 0 1-4 3v2h4v2H10v-2h4v-2a5 5 0 0 1-4-3H9a5 5 0 0 1-5-5V6h3V4zm12 4V8a3 3 0 0 1-3 3h-.2A6.9 6.9 0 0 0 17 8.5V8h2zM5 8.5A6.9 6.9 0 0 0 8.2 11H8a3 3 0 0 1-3-3V8h0v.5z" />
                  </svg>
                ) : null;

              return b.href ? (
                <a
                  href={b.href}
                  target={b.newTab ? "_blank" : undefined}
                  rel={b.newTab ? "noopener noreferrer" : undefined}
                  class={base}
                  aria-label={b.label}
                  title={b.label}
                >
                  {icon}
                  {b.label}
                </a>
              ) : (
                <span class={base} title={b.label}>
                  {icon}
                  {b.label}
                </span>
              );
            })}
          </div>
        </div>
      )
    }
    <a href={href} aria-label={title} class="absolute inset-0 z-0" />
  </div>

  <div class="flex flex-col flex-1 p-5">
    <time
      datetime={typeof date === "string" ? date : date.toISOString()}
      class="text-[11px] text-slate-500 uppercase tracking-wider"
    >
      {formatDate(date)}
    </time>

    <h3 class="mt-2 font-display text-lg sm:text-xl uppercase leading-snug text-brand-ink">
      <a href={href} class="hover:text-brand-primary transition-colors">{title}</a>
    </h3>
    {cardExcerpt && (
      <p class="mt-2 text-sm text-slate-600 line-clamp-3">{cardExcerpt}</p>
    )}
    <a
      href={href}
      class="mt-auto pt-4 inline-flex items-center gap-1 text-xs font-display uppercase text-brand-primary group-hover:underline"
    >
      Czytaj więcej <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
