---
import { formatDate } from "@/lib/format";
import { stripLeadingTitleFromExcerpt } from "@/lib/news-excerpt";

interface Props {
  href: string;
  title: string;
  date: Date | string;
  excerpt: string;
  cover?: string;
  coverAlt?: string;
  tags?: string[];
  facebookUrl?: string;
}

const {
  href,
  title,
  date,
  excerpt,
  cover,
  coverAlt = "",
  tags = [],
  facebookUrl,
} = Astro.props;

const cardExcerpt = stripLeadingTitleFromExcerpt(title, excerpt);
---

<article class="group flex flex-col overflow-hidden rounded-lg bg-white border border-slate-200 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
  <a
    href={href}
    aria-label={title}
    class="relative block aspect-[4/3] overflow-hidden bg-slate-200"
  >
    {cover ? (
      <img
        src={cover}
        alt={coverAlt}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.03]"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-brand-primary to-brand-primary-dark flex items-center justify-center">
        <svg class="w-16 h-16 text-white/20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" />
        </svg>
      </div>
    )}

    <div class="absolute top-3 left-3 right-3 flex items-start justify-between gap-2 pointer-events-none">
      {tags.length > 0 ? (
        <div class="flex gap-1 flex-wrap">
          {tags.slice(0, 1).map((t) => (
            <span class="px-2 py-0.5 rounded bg-brand-secondary text-white uppercase tracking-wide text-[10px] font-display font-bold shadow-sm">
              {t}
            </span>
          ))}
        </div>
      ) : (
        <span></span>
      )}
      {facebookUrl && (
        <span
          class="inline-flex items-center gap-1 bg-[#1877F2]/95 text-white uppercase tracking-wide text-[10px] font-display font-bold px-2 py-0.5 rounded shadow-sm"
          title="Wpis z Facebooka"
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.57V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
          </svg>
          z Facebooka
        </span>
      )}
    </div>
  </a>

  <div class="flex flex-col flex-1 p-5">
    <time
      datetime={typeof date === "string" ? date : date.toISOString()}
      class="text-[11px] text-slate-500 uppercase tracking-wider"
    >
      {formatDate(date)}
    </time>
    <h3 class="mt-2 font-display text-lg sm:text-xl uppercase leading-snug text-brand-ink">
      <a href={href} class="hover:text-brand-primary transition-colors">{title}</a>
    </h3>
    {cardExcerpt && (
      <p class="mt-2 text-sm text-slate-600 line-clamp-3">{cardExcerpt}</p>
    )}
    <a
      href={href}
      class="mt-auto pt-4 inline-flex items-center gap-1 text-xs font-display uppercase text-brand-primary group-hover:underline"
    >
      Czytaj więcej <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
