---
import type { SeasonData } from "@/lib/cms-season";
import { formatDateShort } from "@/lib/format";

type SeasonRound = SeasonData["rounds"][number];
type SeasonMatch = SeasonRound["matches"][number];

interface Props {
  rounds: SeasonRound[];
}

const { rounds } = Astro.props;

function isPlayed(m: SeasonMatch): boolean {
  return Boolean(m.played) && m.homeScore != null && m.awayScore != null;
}

function lastPlayedRound(all: SeasonRound[]): SeasonRound | null {
  for (let i = all.length - 1; i >= 0; i--) {
    const r = all[i];
    if (r?.matches?.some(isPlayed)) return r;
  }
  return null;
}

function matchDateLabel(m: SeasonMatch): string {
  if (!m.date) return "";
  const time = m.time ?? null;
  const d = new Date(`${m.date}T${time || "12:00"}:00+02:00`);
  if (Number.isNaN(d.getTime())) return m.date;
  const dateLabel = formatDateShort(d);
  return time ? `${dateLabel} ${time}` : dateLabel;
}

const round = lastPlayedRound(rounds);
const played = round ? round.matches.filter(isPlayed) : [];
const full = [...played, ...played];
---

{
  round && played.length > 0 && (
    <section class="bg-brand-primary-dark text-white text-xs border-y border-white/10">
      <div class="container mx-auto py-2 flex items-center gap-4">
        <div class="hidden sm:flex items-center gap-2 shrink-0">
          <span class="text-[10px] uppercase tracking-[0.3em] text-white/70 font-display whitespace-nowrap">
            Wyniki kolejki
          </span>
          <span class="font-display text-white/80">K{round.round}</span>
        </div>

        <div class="marka-ticker overflow-hidden flex-1">
          <div class="marka-ticker-track flex whitespace-nowrap py-1.5">
            {full.map((m) => (
              <span class="px-4 shrink-0">
                <span class="text-white/60 font-display">•</span>{" "}
                <span class="text-white/85">{m.home}</span>{" "}
                <span class="font-display text-white">
                  {m.homeScore}:{m.awayScore}
                </span>{" "}
                <span class="text-white/85">{m.away}</span>
                {m.date && (
                  <span class="text-white/50 font-display ml-2">
                    ({matchDateLabel(m)})
                  </span>
                )}
              </span>
            ))}
          </div>
        </div>

        <a
          href="/terminarz"
          class="hidden sm:inline text-[10px] uppercase tracking-widest font-display text-white/70 hover:text-white hover:underline whitespace-nowrap"
        >
          Wszystkie wyniki →
        </a>
      </div>
    </section>
  )
}

