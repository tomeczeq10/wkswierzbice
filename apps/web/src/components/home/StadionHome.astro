---
/**
 * Strona główna w wariancie „Stadion" (lechpoznan.pl + wislakrakow.com inspiration).
 * Sticky LED-style scoreboard u góry, auto-scrolling marquee z meczami,
 * split layout: main content + sticky tabela ligi po prawej.
 */
import type { NewsItem } from "@/lib/cms";
import NewsCard from "@/components/NewsCard.astro";
import SponsorGrid from "@/components/SponsorGrid.astro";
import { SITE, HIGHLIGHTS } from "@/config/site";

interface Match {
  round: number;
  date: string | null;
  time: string | null;
  dateRaw: string | null;
  venue: "home" | "away";
  opponent: string;
  result?: { outcome: "win" | "draw" | "loss"; scoreLabel: string } | null;
}

interface Standing {
  position: number;
  team: string;
  played: number;
  points: number;
  wins: number;
  draws: number;
  losses: number;
  goals: string;
}

interface Props {
  news: NewsItem[];
  upcoming: Match[];
  played: Match[];
  standings: Standing[];
  position: number | null;
  points: number | null;
}

const { news, upcoming, played, standings, position, points } = Astro.props;

const PL_MONTHS_SHORT = ["sty", "lut", "mar", "kwi", "maj", "cze", "lip", "sie", "wrz", "paź", "lis", "gru"];
const PL_WEEKDAYS_SHORT = ["nd", "pn", "wt", "śr", "cz", "pt", "sb"];

const formatMatchTile = (m: Match) => {
  if (!m.date) return { weekday: "TBD", day: "—", month: "", time: m.dateRaw ?? "" };
  const d = new Date(`${m.date}T${m.time ?? "12:00"}:00+02:00`);
  if (Number.isNaN(d.getTime())) return { weekday: "—", day: "—", month: "", time: m.dateRaw ?? "" };
  return {
    weekday: PL_WEEKDAYS_SHORT[d.getDay()],
    day: String(d.getDate()),
    month: PL_MONTHS_SHORT[d.getMonth()],
    time: m.time ?? "",
  };
};

const upcomingMarquee = upcoming.slice(0, 8);
const upcomingTiles = upcoming.slice(0, 5);
const playedRecent = played.slice(-4).reverse();
const standingsTop = standings.slice(0, 10);

const yearsOfTradition = new Date().getFullYear() - SITE.founded;
const wksGoals = standings.find((s) => s.team === "WKS Wierzbice")?.goals ?? "73-31";
const [goalsFor] = wksGoals.split("-").map(Number);

const nextMatch = upcoming[0] ?? null;
const lastMatch = played.length > 0 ? played[played.length - 1] : null;

const outcomeBg = { win: "bg-emerald-500", draw: "bg-amber-500", loss: "bg-rose-600" };
const outcomeLetter = { win: "W", draw: "R", loss: "P" };
const outcomeColor = { win: "text-emerald-400", draw: "text-amber-400", loss: "text-rose-400" };

const matchDateShort = (m: Match | null) => {
  if (!m?.date) return m?.dateRaw ?? "TBD";
  const d = new Date(`${m.date}T${m.time ?? "12:00"}:00+02:00`);
  if (Number.isNaN(d.getTime())) return m.dateRaw ?? m.date;
  return `${d.getDate()}.${String(d.getMonth() + 1).padStart(2, "0")}${m.time ? ` · ${m.time}` : ""}`;
};

const marqueeFull = [...upcomingMarquee, ...upcomingMarquee];
---

{/* ============== STICKY LED SCOREBOARD ============== */}
<div class="sticky top-[72px] z-40 bg-black text-white shadow-2xl">

  {/* LED line — green/red bar */}
  <div class="h-0.5 bg-gradient-to-r from-brand-primary via-brand-secondary to-brand-primary"></div>

  <div class="container mx-auto px-4 py-3 flex flex-wrap items-center gap-x-8 gap-y-2 text-xs">
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5 px-2 py-0.5 bg-brand-secondary text-white text-[9px] uppercase tracking-[0.3em] font-display rounded-sm">
        <span class="w-1 h-1 bg-white rounded-full marka-pulse"></span>
        Live
      </div>
      <span class="font-display text-brand-secondary text-base">{position ?? "–"}.</span>
      <span class="font-display uppercase">WKS</span>
      <span class="text-white/50">{points ?? 0} pkt</span>
    </div>

    {lastMatch && (
      <div class="flex items-center gap-2">
        <span class="text-[9px] uppercase tracking-[0.3em] text-white/40 font-display">Ostatni</span>
        <span class={`font-display text-base ${outcomeColor[lastMatch.result?.outcome ?? "draw"]}`}>
          {lastMatch.result?.scoreLabel ?? "-:-"}
        </span>
        <span class="text-white/70 truncate max-w-[10rem] hidden sm:inline">{lastMatch.opponent}</span>
      </div>
    )}

    {nextMatch && (
      <div class="flex items-center gap-2 ml-auto">
        <span class="text-[9px] uppercase tracking-[0.3em] text-white/40 font-display">Następny</span>
        <span class="text-white/80 truncate max-w-[12rem] hidden sm:inline">{nextMatch.opponent}</span>
        <span class="text-white/50">· {matchDateShort(nextMatch)}</span>
      </div>
    )}
  </div>

  {/* Marquee — przewijane następne mecze */}
  {upcomingMarquee.length > 0 && (
    <div class="marka-ticker overflow-hidden border-t border-white/10 bg-black/80">
      <div class="marka-ticker-track flex whitespace-nowrap py-2 text-[11px]">
        {marqueeFull.map((m) => {
          const t = formatMatchTile(m);
          return (
            <span class="px-6 shrink-0 inline-flex items-center gap-2">
              <span class="text-brand-secondary font-display">●</span>
              <span class="text-white/40 uppercase tracking-widest font-display">K{m.round}</span>
              <span class="text-white/60">{t.day} {t.month}{t.time && ` ${t.time}`}</span>
              <span class="text-white">{m.venue === "home" ? "WKS – " + m.opponent : m.opponent + " – WKS"}</span>
            </span>
          );
        })}
      </div>
    </div>
  )}

  <div class="h-0.5 bg-gradient-to-r from-brand-primary via-brand-secondary to-brand-primary"></div>
</div>

{/* ============== HERO — clean white z herbem ============== */}
<section class="relative bg-white border-b border-slate-200 overflow-hidden">
  <div class="absolute right-0 top-0 bottom-0 w-2/3 lg:w-1/2 opacity-[0.04] pointer-events-none">
    <img src="/herb-wks.png" alt="" class="absolute right-[-10%] top-1/2 -translate-y-1/2 h-[140%] object-contain" />
  </div>

  {/* Stadion light bars — animated gradient */}
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-brand-primary to-transparent stadion-lightbar"></div>

  <div class="relative container mx-auto px-4 py-12 lg:py-16">
    <div class="flex flex-col lg:flex-row lg:items-end gap-6 lg:gap-10 mb-10">
      <img src="/herb-wks.png" alt="Herb WKS Wierzbice" class="w-20 h-20 lg:w-28 lg:h-28 object-contain shrink-0" />
      <div class="flex-1">
        <div class="text-[11px] uppercase tracking-[0.3em] text-brand-primary font-display mb-2">
          {SITE.league}
        </div>
        <h1 class="font-display uppercase tracking-tight text-4xl sm:text-5xl lg:text-6xl leading-[0.95] text-brand-ink">
          {SITE.shortName}
        </h1>
        <p class="mt-3 text-base text-slate-600 max-w-xl">{SITE.tagline}</p>
      </div>
      <div class="flex gap-6 sm:gap-10 shrink-0">
        <div>
          <div class="font-display text-4xl sm:text-5xl text-brand-primary leading-none">
            {position ?? "–"}<span class="text-base text-slate-400 ml-0.5">.</span>
          </div>
          <div class="text-[10px] uppercase tracking-widest text-slate-500 font-display mt-1">w tabeli</div>
        </div>
        <div>
          <div class="font-display text-4xl sm:text-5xl text-brand-ink leading-none">{points ?? "–"}</div>
          <div class="text-[10px] uppercase tracking-widest text-slate-500 font-display mt-1">punktów</div>
        </div>
        <div class="hidden sm:block">
          <div class="font-display text-4xl sm:text-5xl text-brand-secondary leading-none">{goalsFor}</div>
          <div class="text-[10px] uppercase tracking-widest text-slate-500 font-display mt-1">strzelone</div>
        </div>
      </div>
    </div>

    {upcomingTiles.length > 0 && (
      <div class="mt-8">
        <div class="flex items-end justify-between mb-3">
          <div class="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-display">Najbliższe mecze</div>
          <a href="/terminarz" class="text-brand-primary font-display uppercase text-xs tracking-widest hover:underline">
            Pełny terminarz →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
          {upcomingTiles.map((m) => {
            const t = formatMatchTile(m);
            return (
              <div class="border-l-4 border-brand-primary border-t border-r border-b border-slate-200 bg-white px-4 py-4 hover:border-l-brand-secondary transition-all">
                <div class="flex items-baseline gap-2 mb-2">
                  <div class="font-display text-3xl text-brand-ink leading-none">{t.day}</div>
                  <div class="text-[10px] uppercase tracking-widest text-slate-500 font-display">{t.month}<br/>{t.weekday}</div>
                </div>
                <div class="text-xs text-slate-700 truncate font-medium" title={m.opponent}>
                  {m.venue === "home" ? <span class="text-brand-primary font-display">vs</span> : <span class="text-slate-400 font-display">@</span>}
                  {" "}{m.opponent}
                </div>
                {t.time && (
                  <div class="text-[10px] uppercase tracking-widest text-slate-400 font-display mt-1">
                    {t.time}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-brand-primary to-transparent stadion-lightbar"></div>
</section>

{/* ============== SPLIT: main + sticky sidebar (tabela ligi) ============== */}
<section class="bg-slate-50 py-12 lg:py-16">
  <div class="container mx-auto px-4 grid lg:grid-cols-[1fr,22rem] xl:grid-cols-[1fr,26rem] gap-8 lg:gap-12">

    {/* MAIN */}
    <div class="space-y-12">

      {/* Forma WKS — ostatnie wyniki */}
      <div>
        <div class="flex items-end justify-between mb-4">
          <div>
            <div class="text-[10px] uppercase tracking-[0.3em] text-brand-primary font-display">Forma drużyny</div>
            <h2 class="font-display uppercase text-2xl mt-1">Ostatnie wyniki WKS</h2>
          </div>
          <a href="/terminarz" class="text-brand-primary font-display uppercase text-xs tracking-widest hover:underline">
            Wszystkie →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {playedRecent.map((m) => (
            <div class="bg-white border-l-4 border-l-slate-300 border-t border-r border-b border-slate-200 px-4 py-3 flex items-center gap-3 hover:border-l-brand-primary transition-colors">
              <span class={`w-10 h-10 font-display text-base font-bold text-white flex items-center justify-center shrink-0 ${outcomeBg[m.result?.outcome ?? "draw"]}`}>
                {outcomeLetter[m.result?.outcome ?? "draw"]}
              </span>
              <div class="min-w-0 flex-1">
                <div class="text-sm text-brand-ink truncate font-medium">
                  <span class="text-slate-400 mr-1 font-display">{m.venue === "home" ? "vs" : "@"}</span>
                  {m.opponent}
                </div>
                <div class="text-[10px] uppercase tracking-widest text-slate-400 font-display mt-0.5">
                  Kolejka {m.round}
                </div>
              </div>
              <span class="font-display text-2xl text-brand-ink shrink-0">
                {m.result?.scoreLabel ?? "-:-"}
              </span>
            </div>
          ))}
        </div>
      </div>

      {/* Aktualności */}
      {news.length > 0 && (
        <div>
          <div class="flex items-end justify-between mb-4 border-b border-slate-200 pb-3">
            <div>
              <div class="text-[10px] uppercase tracking-[0.3em] text-brand-primary font-display">Aktualności</div>
              <h2 class="font-display uppercase text-2xl mt-1">Co się dzieje w klubie</h2>
            </div>
            <a href="/aktualnosci" class="text-brand-primary font-display uppercase text-xs tracking-widest hover:underline">
              Wszystkie →
            </a>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            {news.slice(0, 4).map((post) => (
              <NewsCard
                href={`/aktualnosci/${post.slug}`}
                title={post.data.title}
                date={post.data.date}
                excerpt={post.data.excerpt}
                cover={post.data.cover}
                coverAlt={post.data.coverAlt}
                tags={post.data.tags}
                facebookUrl={post.data.facebookUrl}
              />
            ))}
          </div>
        </div>
      )}

      {/* Stats inline */}
      <div class="bg-brand-ink text-white px-6 py-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
          <div>
            <div class="font-display text-4xl text-brand-secondary">{HIGHLIGHTS.topScorerGoals}</div>
            <div class="text-[10px] uppercase tracking-widest text-white/50 font-display mt-1">goli Alefe Limy</div>
          </div>
          <div>
            <div class="font-display text-4xl text-white">IV</div>
            <div class="text-[10px] uppercase tracking-widest text-white/50 font-display mt-1">liga (2021/22)</div>
          </div>
          <div>
            <div class="font-display text-4xl text-brand-secondary">{yearsOfTradition}</div>
            <div class="text-[10px] uppercase tracking-widest text-white/50 font-display mt-1">lat klubu</div>
          </div>
          <div>
            <div class="font-display text-4xl text-white">5</div>
            <div class="text-[10px] uppercase tracking-widest text-white/50 font-display mt-1">grup wiekowych</div>
          </div>
        </div>
      </div>

    </div>

    {/* STICKY SIDEBAR — tabela ligi */}
    <aside class="lg:sticky lg:top-[180px] lg:self-start">
      <div class="bg-white border border-slate-200">
        <div class="bg-brand-ink text-white px-4 py-3 flex items-center justify-between">
          <div>
            <div class="text-[9px] uppercase tracking-[0.3em] text-brand-secondary font-display">Tabela ligi</div>
            <div class="font-display uppercase text-sm">Klasa okręgowa Wrocław</div>
          </div>
          <a href="/terminarz" class="text-brand-secondary text-[10px] uppercase tracking-widest font-display hover:underline">
            Cała →
          </a>
        </div>

        <table class="w-full text-sm">
          <thead class="bg-slate-100 text-[9px] uppercase tracking-widest text-slate-500 font-display">
            <tr>
              <th class="px-3 py-2 text-left w-8">#</th>
              <th class="px-3 py-2 text-left">Drużyna</th>
              <th class="px-2 py-2 text-center w-8">M</th>
              <th class="px-3 py-2 text-center w-10">Pkt</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {standingsTop.map((s) => {
              const isWks = s.team === "WKS Wierzbice";
              return (
                <tr class={isWks ? "bg-brand-primary/10 font-medium" : ""}>
                  <td class="px-3 py-2 font-display text-slate-600">{s.position}</td>
                  <td class="px-3 py-2 truncate max-w-[10rem]">
                    <span class={isWks ? "text-brand-primary font-display uppercase" : "text-brand-ink"}>
                      {s.team}
                    </span>
                  </td>
                  <td class="px-2 py-2 text-center text-slate-600 text-xs">{s.played}</td>
                  <td class="px-3 py-2 text-center font-display text-brand-ink">{s.points}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Mini sponsors */}
      <div class="mt-6 bg-white border border-slate-200 p-4">
        <div class="text-[9px] uppercase tracking-[0.3em] text-brand-primary font-display mb-3">Sponsor strategiczny</div>
        <div class="text-sm font-display uppercase text-brand-ink">Gmina Kobierzyce</div>
        <a href="/sponsorzy" class="text-[10px] uppercase tracking-widest font-display text-brand-primary hover:underline mt-2 inline-block">
          Wszyscy partnerzy →
        </a>
      </div>
    </aside>

  </div>
</section>

{/* CTA Nabory */}
<section class="bg-brand-primary text-white">
  <div class="container mx-auto px-4 py-12 flex flex-col md:flex-row items-center gap-6 md:gap-10">
    <div class="flex-1 text-center md:text-left">
      <div class="text-[10px] uppercase tracking-[0.3em] text-brand-secondary font-display mb-1">Nabory otwarte</div>
      <h2 class="font-display uppercase text-2xl sm:text-3xl">Dołącz do akademii WKS</h2>
      <p class="mt-2 text-sm text-white/80 max-w-xl">
        Trenujemy żaków, orliki, trampkarzy i juniorów. Pierwszy trening bez zobowiązań.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/nabory" class="btn bg-white text-brand-primary hover:bg-brand-secondary hover:text-white">Zapisz dziecko</a>
      <a href="/kontakt" class="btn-outline text-white border-white hover:bg-white hover:text-brand-primary">Kontakt</a>
    </div>
  </div>
</section>

{/* Sponsors strip */}
<section class="bg-white py-10">
  <div class="container mx-auto px-4">
    <div class="text-center mb-6">
      <div class="text-[10px] uppercase tracking-[0.3em] text-brand-primary font-display">Partnerzy klubu</div>
    </div>
    <SponsorGrid />
  </div>
</section>
