---
interface Result {
  outcome: "win" | "draw" | "loss";
  scoreLabel: string;
}
interface Match {
  round: number;
  date: string | null;
  time: string | null;
  dateRaw: string | null;
  venue: "home" | "away";
  opponent: string;
  result?: Result | null;
}
interface Props {
  lastMatch?: Match | null;
  nextMatch?: Match | null;
  position?: number | null;
  points?: number | null;
}

const { lastMatch, nextMatch, position, points } = Astro.props;

const outcomeColor = {
  win: "text-emerald-400",
  draw: "text-amber-400",
  loss: "text-rose-400",
};
const outcomeLabel = { win: "W", draw: "R", loss: "P" };

const formatShortDate = (dateStr: string | null, time: string | null, raw: string | null) => {
  if (!dateStr) return raw ?? "TBD";
  const d = new Date(`${dateStr}T${time ?? "12:00"}:00+02:00`);
  if (isNaN(d.getTime())) return raw ?? dateStr;
  return `${d.getDate()}.${String(d.getMonth() + 1).padStart(2, "0")} ${time ?? ""}`.trim();
};
---

<div class="bg-brand-primary-dark text-white text-xs">
  <div class="container mx-auto flex flex-wrap items-stretch divide-x divide-white/10">

    {lastMatch && (
      <div class="flex items-center gap-3 px-4 py-2.5 min-w-0">
        <span class="uppercase tracking-widest text-white/50 shrink-0">Ostatni</span>
        <span class={`font-display text-base font-bold shrink-0 ${outcomeColor[lastMatch.result?.outcome ?? "draw"]}`}>
          {lastMatch.result?.scoreLabel ?? "-:-"}
        </span>
        <span class="text-white/80 truncate hidden sm:block">{lastMatch.opponent}</span>
        <span class={`shrink-0 w-5 h-5 rounded text-center text-[10px] font-display font-bold leading-5 ${
          lastMatch.result?.outcome === "win" ? "bg-emerald-600" :
          lastMatch.result?.outcome === "loss" ? "bg-rose-700" : "bg-amber-600"
        }`}>
          {outcomeLabel[lastMatch.result?.outcome ?? "draw"]}
        </span>
      </div>
    )}

    <div class="flex items-center gap-2 px-4 py-2.5 flex-1 justify-center">
      <svg class="w-3.5 h-3.5 text-brand-secondary shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span class="font-display text-sm uppercase tracking-wide">
        {position ? `${position}. miejsce` : "Wicelider"}
      </span>
      <span class="text-white/40 hidden md:inline">Klasa okręgowa Wrocław</span>
    </div>

    {nextMatch && (
      <div class="flex items-center gap-3 px-4 py-2.5 min-w-0">
        <span class="uppercase tracking-widest text-white/50 shrink-0">Następny</span>
        <span class="font-display text-sm text-white/90 truncate hidden sm:block">{nextMatch.opponent}</span>
        <span class="text-white/60 shrink-0">
          {formatShortDate(nextMatch.date, nextMatch.time, nextMatch.dateRaw)}
        </span>
        <a href="/terminarz" class="shrink-0 text-brand-secondary uppercase tracking-widest hover:underline hidden md:inline">
          Terminarz →
        </a>
      </div>
    )}

  </div>
</div>
