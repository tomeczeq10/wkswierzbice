---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LiveBanner from "@/components/LiveBanner.astro";
import { fetchSiteConfig } from "@/lib/cms-site";
import { fetchSeason } from "@/lib/cms-season";
import TemplateInit from "@/templates/init.astro";
import TemplateSwitcher from "@/templates/TemplateSwitcher.astro";
import KlasykStickyLeagueBar from "@/components/home/KlasykStickyLeagueBar.astro";

const cfg = await fetchSiteConfig();
const SITE = cfg.site;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.defaultOgImage,
  noIndex = false,
} = Astro.props;

const fullTitle = title ? `${title} | ${SITE.shortName}` : SITE.shortName;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();
const ogImage = new URL(image, Astro.site ?? SITE.url).toString();

// Globalny pasek ligowy pod headerem (tylko dla klasyka; ukrywany CSS-em dla innych template'ów).
const season = await fetchSeason();
const wksStanding = season.standings.find((s) => s.team === "WKS Wierzbice");
const wksPosition = wksStanding?.position ?? null;
const wksPoints = wksStanding?.points ?? null;
const nextMatch = season.wks.upcoming[0] ?? null;
const lastMatch = [...season.wks.played].reverse()[0] ?? null;
const form = [...season.wks.played].reverse().slice(0, 5).map((m) => m.result?.outcome ?? "draw");
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#15803d" />

    <TemplateInit />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsOrganization",
      "name": SITE.name,
      "alternateName": SITE.shortName,
      "url": SITE.url,
      "logo": `${SITE.url}/herb-wks.png`,
      "foundingDate": String(SITE.founded),
      "sport": "Piłka nożna",
      "description": SITE.description,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": cfg.contact.address.street,
        "postalCode": cfg.contact.address.postalCode,
        "addressLocality": cfg.contact.address.city,
        "addressCountry": "PL",
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": cfg.contact.phone.replace(/\\s+/g, ""),
        "email": cfg.contact.email,
        "contactType": "customer service",
        "availableLanguage": "Polish",
      },
      "sameAs": [
        cfg.social.facebook,
      ],
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand-primary focus:text-white focus:rounded"
    >
      Przejdź do treści
    </a>
    <LiveBanner />
    <Header />
    <div data-template-only="klasyk">
      <KlasykStickyLeagueBar
        position={wksPosition}
        points={wksPoints}
        lastMatch={lastMatch}
        nextMatch={nextMatch}
        upcoming={season.wks.upcoming}
        form={form}
        rounds={season.rounds}
      />
    </div>
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <TemplateSwitcher />
  </body>
</html>
