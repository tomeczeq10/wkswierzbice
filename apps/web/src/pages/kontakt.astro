---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ContactForm from "@/components/ContactForm.astro";
import { CONTACT, SOCIAL, SITE } from "@/config/site";
---

<BaseLayout
  title="Kontakt"
  description={`Skontaktuj się z klubem ${SITE.name}. Adres stadionu, telefon, email, mapa.`}
>
  <PageHeader
    kicker="Kontakt"
    title="Napisz, zadzwoń, odwiedź"
    description="Masz pytanie? Chcesz zostać sponsorem? Zapisać dziecko? Jesteśmy do dyspozycji."
  />

  <section class="section">
    <div class="container mx-auto grid lg:grid-cols-2 gap-12">
      <div>
        <h2 class="section-title">Dane kontaktowe</h2>

        <div class="mt-8 space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500">Adres</div>
              <address class="not-italic mt-1 text-slate-700">
                <strong>{SITE.name}</strong><br/>
                {CONTACT.address.street}<br/>
                {CONTACT.address.postalCode} {CONTACT.address.city}
              </address>
              <a href={CONTACT.googleMapsLink} target="_blank" rel="noopener" class="text-brand-primary text-sm mt-2 inline-block hover:underline">
                Otwórz w Google Maps →
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z"/></svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500">Telefon</div>
              <a href={`tel:${CONTACT.phone.replace(/\s+/g, "")}`} class="text-lg text-brand-ink hover:text-brand-primary font-medium mt-1 block">
                {CONTACT.phone}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><path d="M2 6l10 7 10-7"/></svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500">Email</div>
              <a href={`mailto:${CONTACT.email}`} class="text-lg text-brand-ink hover:text-brand-primary font-medium mt-1 block">
                {CONTACT.email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500">Social media</div>
              <div class="mt-1 flex flex-wrap gap-4 text-sm">
                {SOCIAL.facebook && <a href={SOCIAL.facebook} target="_blank" rel="noopener" class="text-brand-primary hover:underline">Facebook</a>}
                {SOCIAL.instagram && <a href={SOCIAL.instagram} target="_blank" rel="noopener" class="text-brand-primary hover:underline">Instagram</a>}
                {SOCIAL.youtube && <a href={SOCIAL.youtube} target="_blank" rel="noopener" class="text-brand-primary hover:underline">YouTube</a>}
                {SOCIAL.tiktok && <a href={SOCIAL.tiktok} target="_blank" rel="noopener" class="text-brand-primary hover:underline">TikTok</a>}
              </div>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-lg overflow-hidden border border-slate-200 aspect-[4/3]">
          <iframe
            src={CONTACT.googleMapsEmbedSrc}
            title="Mapa – lokalizacja stadionu"
            loading="lazy"
            class="w-full h-full"
            style="border: 0;"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div>
        <h2 class="section-title">Napisz do nas</h2>
        <div class="card p-6 sm:p-8 mt-8">
          <ContactForm variant="contact" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
