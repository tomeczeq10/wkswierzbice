---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ContactForm from "@/components/ContactForm.astro";
import { CONTACT } from "@/config/site";

const groups = [
  {
    category: "Żaki",
    years: "rocznik 2017 i młodsze",
    days: "pon., śr. – popołudnia",
    coach: "Sztab młodzieżowy",
    description: "Pierwsze treningi – zabawa, radość z piłki i podstawy koordynacji.",
  },
  {
    category: "Orliki (D1)",
    years: "rocznik 2015–2016",
    days: "wt., czw. – popołudnia",
    coach: "Sztab młodzieżowy",
    description: "Technika indywidualna, gra 1×1 i pierwsze zasady taktyczne.",
  },
  {
    category: "Trampkarze (C1)",
    years: "rocznik 2011–2012",
    days: "pon., śr., pt. – popołudnia",
    coach: "Sztab młodzieżowy",
    description: "Rozwój taktyczny na pełnowymiarowym boisku i gra w lidze okręgowej.",
  },
  {
    category: "Juniorzy",
    years: "rocznik 2008–2011",
    days: "pon., śr., pt. – popołudnia",
    coach: "Sztab młodzieżowy",
    description: "Pełne przygotowanie do gry w pierwszej drużynie i lidze DZPN.",
  },
];
---

<BaseLayout
  title="Nabory"
  description="Otwarte nabory do drużyn młodzieżowych klubu. Roczniki, godziny treningów i formularz zgłoszeniowy."
>
  <PageHeader
    kicker="Zapisy"
    title="Dołącz do naszej drużyny"
    description="Prowadzimy otwarte nabory przez cały rok. Pierwszy trening bez zobowiązań – dziecko po prostu przychodzi i próbuje."
  />

  <section class="section">
    <div class="container mx-auto">
      <h2 class="section-title text-center mb-12">Grupy wiekowe</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          groups.map((g) => (
            <div class="card p-6">
              <div class="text-xs uppercase tracking-widest text-brand-primary font-display">
                {g.years}
              </div>
              <h3 class="text-2xl mt-1">{g.category}</h3>
              <dl class="mt-4 text-sm space-y-2">
                <div>
                  <dt class="text-slate-500 text-xs uppercase tracking-wider">Treningi</dt>
                  <dd class="font-medium">{g.days}</dd>
                </div>
                <div>
                  <dt class="text-slate-500 text-xs uppercase tracking-wider">Trener</dt>
                  <dd class="font-medium">{g.coach}</dd>
                </div>
              </dl>
              <p class="mt-4 text-sm text-slate-600">{g.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section bg-slate-50">
    <div class="container mx-auto grid lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2">
        <span class="section-kicker">Formularz zgłoszeniowy</span>
        <h2 class="section-title">Zapisz dziecko</h2>
        <p class="mt-4 text-slate-600">
          Wypełnij formularz, a nasz koordynator skontaktuje się z Tobą w ciągu 48 godzin
          z informacją o terminie pierwszego treningu i potrzebnych dokumentach.
        </p>
        <div class="mt-8 card p-5">
          <h3 class="text-lg">Co przynieść na pierwszy trening?</h3>
          <ul class="mt-3 text-sm space-y-2 text-slate-600">
            <li class="flex gap-2"><span class="text-brand-primary">✓</span> Strój sportowy i dres</li>
            <li class="flex gap-2"><span class="text-brand-primary">✓</span> Buty sportowe (na trawę lub halowe)</li>
            <li class="flex gap-2"><span class="text-brand-primary">✓</span> Bidon z wodą</li>
            <li class="flex gap-2"><span class="text-brand-primary">✓</span> Zgodę rodzica na udział w treningu</li>
          </ul>
        </div>
        <div class="mt-6 text-sm text-slate-600">
          <p><strong>Masz pytania?</strong></p>
          <p>Zadzwoń: <a href={`tel:${CONTACT.phone.replace(/\s+/g, "")}`} class="text-brand-primary font-medium">{CONTACT.phone}</a></p>
          <p>Napisz: <a href={`mailto:${CONTACT.email}`} class="text-brand-primary font-medium">{CONTACT.email}</a></p>
        </div>
      </div>
      <div class="lg:col-span-3">
        <div class="card p-6 sm:p-8">
          <ContactForm variant="join" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
