---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import NewsCard from "@/components/NewsCard.astro";
import { fetchNewsList } from "@/lib/cms";

const posts = await fetchNewsList();
---

<BaseLayout
  title="Aktualności"
  description="Aktualności z życia klubu – mecze, treningi, nabory i wydarzenia WKS Wierzbice."
>
  <PageHeader
    kicker="Aktualności"
    title="Co słychać w klubie"
    description="Wyniki, relacje z meczów, informacje o naborach i wydarzeniach klubowych."
  />

  <section class="section">
    <div class="container mx-auto">
      {
        posts.length === 0 ? (
          <p class="text-center text-slate-500">Na razie brak aktualności. Zajrzyj wkrótce.</p>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <NewsCard
                href={`/aktualnosci/${post.slug}`}
                title={post.data.title}
                date={post.data.date}
                excerpt={post.data.excerpt}
                cover={post.data.cover}
                coverAlt={post.data.coverAlt}
                tags={post.data.tags}
                facebookUrl={post.data.facebookUrl}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
