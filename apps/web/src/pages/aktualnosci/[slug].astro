---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/format";
import {
  fetchNewsList,
  pickArticleBodyCoverUrl,
  pickCoverUrl,
  resolveCoverAlt,
  type NewsItem,
} from "@/lib/cms";
import { lexicalToHtml } from "@/lib/lexical";
import { stripLeadingTitleFromExcerpt } from "@/lib/news-excerpt";

// SSR (`output: "server"`): `getStaticPaths` jest ignorowane — patrz `druzyny/[slug].astro`.
const slug = Astro.params.slug;
if (!slug || typeof slug !== "string") {
  return Astro.redirect("/404");
}
const posts = await fetchNewsList();
const post = posts.find((p) => p.slug === slug);
if (!post) {
  return Astro.redirect("/404");
}
const { title, date, tags, author, excerpt, facebookUrl, truncated } = post.data;
const ogImageUrl =
  pickCoverUrl(post.data.cover, "hero") ??
  pickCoverUrl(post.data.cover, "card") ??
  pickArticleBodyCoverUrl(post.data.cover);
const articleCoverUrl = pickArticleBodyCoverUrl(post.data.cover);
const coverAlt = resolveCoverAlt(post);
const headerExcerpt = stripLeadingTitleFromExcerpt(title, excerpt);

let bodyHtml: string | null = null;
let MdContent: Awaited<ReturnType<Extract<NewsItem["body"], { type: "md" }>["entry"]["render"]>>["Content"] | null = null;

if (post.body.type === "lexical") {
  bodyHtml = await lexicalToHtml(post.body.value);
} else if (post.body.type === "md") {
  const rendered = await post.body.entry.render();
  MdContent = rendered.Content;
}
---

<BaseLayout
  title={title}
  description={headerExcerpt || excerpt}
  image={ogImageUrl}
>
  <article>
    <header class="bg-brand-ink text-white">
      <div class="container mx-auto py-16 sm:py-20 max-w-4xl">
        <a href="/aktualnosci" class="inline-flex items-center gap-1 text-sm text-brand-secondary hover:underline mb-4">
          ← Wszystkie aktualności
        </a>
        <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-widest text-slate-300 mb-4">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          <span aria-hidden="true">&middot;</span>
          <span>{author}</span>
          {
            tags.map((t) => (
              <span class="px-2 py-0.5 rounded bg-brand-primary/80 text-white">{t}</span>
            ))
          }
        </div>
        <h1>{title}</h1>
        <p class="mt-4 text-lg text-slate-200 max-w-2xl">{headerExcerpt}</p>
      </div>
    </header>

    {
      articleCoverUrl && (
        <div class="container mx-auto max-w-4xl -mt-4 sm:-mt-6 relative z-10 px-4">
          <figure class="rounded-xl shadow-xl overflow-hidden bg-slate-100 max-w-3xl mx-auto">
            <img
              src={articleCoverUrl}
              alt={coverAlt}
              class="w-full h-auto max-h-[min(85vh,1400px)] object-contain mx-auto block"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        </div>
      )
    }

    <div class="section">
      <div class="container mx-auto max-w-3xl">
        <div class="prose-club">
          {MdContent ? <MdContent /> : bodyHtml ? <Fragment set:html={bodyHtml} /> : null}
        </div>

        {
          facebookUrl && (
            <div class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-6 flex flex-col sm:flex-row sm:items-center gap-4 sm:justify-between">
              <div>
                <p class="font-display text-lg uppercase text-brand-ink">
                  {truncated ? "Pełna treść na Facebooku" : "Zobacz oryginalny wpis"}
                </p>
                <p class="text-sm text-slate-600 mt-1">
                  {truncated
                    ? "Ten wpis pochodzi z fanpage'a klubu – zdjęcia i pełny tekst dostępne są w oryginalnym poście."
                    : "Wszystkie zdjęcia, komentarze i reakcje znajdziesz w oryginalnym poście na Facebooku."}
                </p>
              </div>
              <a
                href={facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-[#1877F2] hover:bg-[#145dbf] text-white font-display uppercase text-sm px-5 py-3 rounded-lg transition-colors whitespace-nowrap"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.57V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
                </svg>
                Zobacz na Facebooku
              </a>
            </div>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>
