---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import GalleryGrid from "@/components/GalleryGrid.astro";
import { fetchGalleryIndex } from "@/lib/cms-gallery";
import { formatDate } from "@/lib/format";

const mode = await fetchGalleryIndex();

const MONTHS_PL = [
  "Styczeń",
  "Luty",
  "Marzec",
  "Kwiecień",
  "Maj",
  "Czerwiec",
  "Lipiec",
  "Sierpień",
  "Wrzesień",
  "Październik",
  "Listopad",
  "Grudzień",
];

// Opcje filtra: lista (year, month) zbiorów, w których jakiś album ma eventDate.
// Pełna lista miesięcy danego roku pokazywana dopiero po wybraniu roku — selektory
// kaskadowe sterowane JS-em. Tutaj zbieramy tylko zbiór par {year, month}.
type YearMonth = { year: number; month: number };
let availableYears: number[] = [];
let availableYearMonths: YearMonth[] = [];

if (mode.kind === "albums") {
  const seenYM = new Set<string>();
  for (const al of mode.albums) {
    if (!al.eventDate) continue;
    const d = new Date(al.eventDate);
    if (Number.isNaN(d.getTime())) continue;
    const y = d.getFullYear();
    const m = d.getMonth() + 1;
    const key = `${y}-${m}`;
    if (!seenYM.has(key)) {
      seenYM.add(key);
      availableYearMonths.push({ year: y, month: m });
    }
  }
  availableYears = Array.from(new Set(availableYearMonths.map((x) => x.year))).sort(
    (a, b) => b - a,
  );
}

const showFilter = mode.kind === "albums" && availableYears.length > 0;
---

<BaseLayout
  title="Galeria"
  description="Zdjęcia z meczów, treningów i wydarzeń klubowych WKS Wierzbice."
>
  <PageHeader
    kicker="Galeria"
    title="Zdjęcia z życia klubu"
    description="Najlepsze ujęcia z meczów, treningów i uroczystości klubowych."
  />

  <section class="section">
    <div class="container mx-auto">
      {
        mode.kind === "albums" ? (
          <>
            {showFilter && (
              <div
                id="gallery-filter"
                class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:gap-4"
                data-year-months={JSON.stringify(availableYearMonths)}
              >
                <div class="flex flex-col gap-1">
                  <label for="filter-year" class="text-xs font-semibold uppercase tracking-wider text-brand-muted">
                    Rok
                  </label>
                  <select
                    id="filter-year"
                    class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20"
                  >
                    <option value="">Wszystkie</option>
                    {availableYears.map((y) => (
                      <option value={String(y)}>{y}</option>
                    ))}
                  </select>
                </div>
                <div class="flex flex-col gap-1">
                  <label for="filter-month" class="text-xs font-semibold uppercase tracking-wider text-brand-muted">
                    Miesiąc
                  </label>
                  <select
                    id="filter-month"
                    class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20 disabled:bg-slate-100 disabled:text-slate-400"
                    disabled
                  >
                    <option value="">Wszystkie</option>
                  </select>
                </div>
                <button
                  id="filter-reset"
                  type="button"
                  class="btn btn-outline self-start text-sm sm:self-end"
                >
                  Wyczyść
                </button>
                <p
                  id="filter-status"
                  class="text-sm text-brand-muted sm:ml-auto sm:self-end"
                  aria-live="polite"
                ></p>
              </div>
            )}
            <div id="gallery-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {mode.albums.map((al) => {
                const d = al.eventDate ? new Date(al.eventDate) : null;
                const hasDate = d && !Number.isNaN(d.getTime());
                return (
                <a
                  href={`/galeria/${al.slug}`}
                  class="album-card card group flex flex-col overflow-hidden p-0 no-underline text-inherit hover:no-underline focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:outline-none"
                  data-year={hasDate ? String(d!.getFullYear()) : ""}
                  data-month={hasDate ? String(d!.getMonth() + 1) : ""}
                >
                  <div class="relative aspect-[4/3] bg-slate-200 overflow-hidden">
                    {al.coverSrc ? (
                      <img
                        src={al.coverSrc}
                        alt=""
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-slate-100 text-brand-muted font-display text-sm uppercase tracking-wider">
                        Galeria
                      </div>
                    )}
                    <span class="absolute inset-0 bg-brand-ink/0 transition-colors group-hover:bg-brand-ink/25" />
                    {al.subAlbumCount > 0 && (
                      <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-brand-ink/70 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                        <svg class="w-3 h-3 opacity-80" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                          <path d="M1.5 2A1.5 1.5 0 0 0 0 3.5v2A1.5 1.5 0 0 0 1.5 7h6A1.5 1.5 0 0 0 9 5.5v-2A1.5 1.5 0 0 0 7.5 2h-6zM0 10.5A1.5 1.5 0 0 1 1.5 9h13A1.5 1.5 0 0 1 16 10.5v2A1.5 1.5 0 0 1 14.5 14h-13A1.5 1.5 0 0 1 0 12.5v-2z"/>
                        </svg>
                        {al.subAlbumCount === 1 ? "1 album" : `${al.subAlbumCount} albumy`}
                      </span>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col gap-1 p-4">
                    <h2 class="font-display text-xl uppercase tracking-tight text-brand-ink group-hover:text-brand-primary transition-colors">
                      {al.title}
                    </h2>
                    {al.eventDate ? (
                      <p class="text-sm text-brand-muted">{formatDate(al.eventDate)}</p>
                    ) : null}
                    {al.description ? (
                      <p class="text-sm text-slate-600 line-clamp-2">{al.description}</p>
                    ) : null}
                    <p class="mt-auto pt-2 text-sm font-medium text-brand-primary">
                      {al.subAlbumCount > 0
                        ? `${al.subAlbumCount === 1 ? "1 album" : `${al.subAlbumCount} albumy`} · ${al.photoCount} zdjęć →`
                        : al.photoCount === 1
                          ? "1 zdjęcie →"
                          : `${al.photoCount} zdjęć →`}
                    </p>
                  </div>
                </a>
                );
              })}
            </div>
            <p
              id="gallery-empty"
              class="hidden text-center text-brand-muted py-12"
            >
              Brak albumów dla wybranego okresu.
            </p>
            {mode.albums.length === 0 && mode.orphanCount === 0 ? (
              <p class="text-center text-brand-muted py-12">
                Wkrótce pojawią się tu albumy ze zdjęciami — sprawdź ponownie.
              </p>
            ) : null}
            {mode.orphanCount > 0 ? (
              <div class="mt-12 border-t border-slate-200 pt-10">
                <a
                  href="/galeria/bez-albumu"
                  class="card flex flex-col gap-2 p-6 sm:flex-row sm:items-center sm:justify-between no-underline text-inherit hover:border-brand-primary/40 focus-visible:ring-2 focus-visible:ring-brand-primary"
                >
                  <div>
                    <h2 class="font-display text-lg uppercase tracking-tight text-brand-ink">Pozostałe zdjęcia</h2>
                    <p class="text-sm text-brand-muted">
                      Zdjęcia bez przypisanego albumu w panelu ({mode.orphanCount})
                    </p>
                  </div>
                  <span class="btn btn-outline shrink-0 self-start sm:self-center">Otwórz</span>
                </a>
              </div>
            ) : null}
          </>
        ) : (
          <GalleryGrid items={mode.items} />
        )
      }
    </div>
  </section>

  {showFilter && (
    <script is:inline define:vars={{ MONTHS_PL, availableYearMonths }}>
      (() => {
        const yearSel = document.getElementById("filter-year");
        const monthSel = document.getElementById("filter-month");
        const reset = document.getElementById("filter-reset");
        const status = document.getElementById("filter-status");
        const empty = document.getElementById("gallery-empty");
        const cards = Array.from(document.querySelectorAll(".album-card"));
        if (!yearSel || !monthSel || !cards.length) return;

        const monthsByYear = new Map();
        for (const ym of availableYearMonths) {
          if (!monthsByYear.has(ym.year)) monthsByYear.set(ym.year, new Set());
          monthsByYear.get(ym.year).add(ym.month);
        }

        const refreshMonths = () => {
          const y = yearSel.value;
          monthSel.innerHTML = '<option value="">Wszystkie</option>';
          if (!y) {
            monthSel.disabled = true;
            monthSel.value = "";
            return;
          }
          const months = Array.from(monthsByYear.get(Number(y)) || []).sort(
            (a, b) => a - b,
          );
          for (const m of months) {
            const opt = document.createElement("option");
            opt.value = String(m);
            opt.textContent = MONTHS_PL[m - 1];
            monthSel.appendChild(opt);
          }
          monthSel.disabled = months.length === 0;
        };

        const apply = () => {
          const y = yearSel.value;
          const m = monthSel.value;
          let visible = 0;
          for (const card of cards) {
            const cy = card.dataset.year || "";
            const cm = card.dataset.month || "";
            const ok = (!y || cy === y) && (!m || cm === m);
            card.classList.toggle("hidden", !ok);
            if (ok) visible++;
          }
          if (empty) empty.classList.toggle("hidden", visible !== 0);
          if (status) {
            if (!y && !m) {
              status.textContent = "";
            } else {
              status.textContent =
                visible === 1
                  ? "Znaleziono 1 album"
                  : `Znaleziono ${visible} ${visible % 10 >= 2 && visible % 10 <= 4 && (visible % 100 < 10 || visible % 100 >= 20) ? "albumy" : "albumów"}`;
            }
          }
        };

        yearSel.addEventListener("change", () => {
          refreshMonths();
          apply();
        });
        monthSel.addEventListener("change", apply);
        reset?.addEventListener("click", () => {
          yearSel.value = "";
          refreshMonths();
          apply();
        });
      })();
    </script>
  )}
</BaseLayout>
