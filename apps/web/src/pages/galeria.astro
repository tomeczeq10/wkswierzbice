---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import GalleryGrid from "@/components/GalleryGrid.astro";
import { fetchGalleryIndex } from "@/lib/cms-gallery";
import { formatDate } from "@/lib/format";

const mode = await fetchGalleryIndex();
---

<BaseLayout
  title="Galeria"
  description="Zdjęcia z meczów, treningów i wydarzeń klubowych WKS Wierzbice."
>
  <PageHeader
    kicker="Galeria"
    title="Zdjęcia z życia klubu"
    description="Najlepsze ujęcia z meczów, treningów i uroczystości klubowych."
  />

  <section class="section">
    <div class="container mx-auto">
      {
        mode.kind === "albums" ? (
          <>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {mode.albums.map((al) => (
                <a
                  href={`/galeria/${al.slug}`}
                  class="card group flex flex-col overflow-hidden p-0 no-underline text-inherit hover:no-underline focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:outline-none"
                >
                  <div class="relative aspect-[4/3] bg-slate-200 overflow-hidden">
                    {al.coverSrc ? (
                      <img
                        src={al.coverSrc}
                        alt=""
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-slate-100 text-brand-muted font-display text-sm uppercase tracking-wider">
                        Galeria
                      </div>
                    )}
                    <span class="absolute inset-0 bg-brand-ink/0 transition-colors group-hover:bg-brand-ink/25" />
                    {al.subAlbumCount > 0 && (
                      <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-brand-ink/70 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                        <svg class="w-3 h-3 opacity-80" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                          <path d="M1.5 2A1.5 1.5 0 0 0 0 3.5v2A1.5 1.5 0 0 0 1.5 7h6A1.5 1.5 0 0 0 9 5.5v-2A1.5 1.5 0 0 0 7.5 2h-6zM0 10.5A1.5 1.5 0 0 1 1.5 9h13A1.5 1.5 0 0 1 16 10.5v2A1.5 1.5 0 0 1 14.5 14h-13A1.5 1.5 0 0 1 0 12.5v-2z"/>
                        </svg>
                        {al.subAlbumCount === 1 ? "1 album" : `${al.subAlbumCount} albumy`}
                      </span>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col gap-1 p-4">
                    <h2 class="font-display text-xl uppercase tracking-tight text-brand-ink group-hover:text-brand-primary transition-colors">
                      {al.title}
                    </h2>
                    {al.eventDate ? (
                      <p class="text-sm text-brand-muted">{formatDate(al.eventDate)}</p>
                    ) : null}
                    {al.description ? (
                      <p class="text-sm text-slate-600 line-clamp-2">{al.description}</p>
                    ) : null}
                    <p class="mt-auto pt-2 text-sm font-medium text-brand-primary">
                      {al.subAlbumCount > 0
                        ? `${al.subAlbumCount === 1 ? "1 album" : `${al.subAlbumCount} albumy`} · ${al.photoCount} zdjęć →`
                        : al.photoCount === 1
                          ? "1 zdjęcie →"
                          : `${al.photoCount} zdjęć →`}
                    </p>
                  </div>
                </a>
              ))}
            </div>
            {mode.albums.length === 0 && mode.orphanCount === 0 ? (
              <p class="text-center text-brand-muted py-12">
                Wkrótce pojawią się tu albumy ze zdjęciami — sprawdź ponownie.
              </p>
            ) : null}
            {mode.orphanCount > 0 ? (
              <div class="mt-12 border-t border-slate-200 pt-10">
                <a
                  href="/galeria/bez-albumu"
                  class="card flex flex-col gap-2 p-6 sm:flex-row sm:items-center sm:justify-between no-underline text-inherit hover:border-brand-primary/40 focus-visible:ring-2 focus-visible:ring-brand-primary"
                >
                  <div>
                    <h2 class="font-display text-lg uppercase tracking-tight text-brand-ink">Pozostałe zdjęcia</h2>
                    <p class="text-sm text-brand-muted">
                      Zdjęcia bez przypisanego albumu w panelu ({mode.orphanCount})
                    </p>
                  </div>
                  <span class="btn btn-outline shrink-0 self-start sm:self-center">Otwórz</span>
                </a>
              </div>
            ) : null}
          </>
        ) : (
          <GalleryGrid items={mode.items} />
        )
      }
    </div>
  </section>
</BaseLayout>
