---
/**
 * /live — dedykowana strona relacji na żywo.
 *
 * Architektura:
 *  - SSR ładuje początkowy snapshot przez fetchLiveMatch() (bez cache).
 *  - Inline `<script>` na stronie podpina się do SSE (`/wks-live-match/stream`)
 *    z fallback'iem polling co 3s (`/wks-live-match`). Aktualizuje DOM imperatywnie.
 *  - Strona jest CAŁKOWICIE odizolowana od reszty layoutu (hero, header, banery
 *    template'ów). Bez Cloudflare cache, bez SSR view-transitions, bez konkurencji.
 *
 * UX:
 *  - Pełnoekranowa, ciemna (zielony klubowy + akcenty).
 *  - Wielki scoreboard (drużyny, wynik, zegar, stan meczu).
 *  - Timeline eventów (gole, kartki) w jednej kolumnie chronologicznie.
 *  - Animowana kropka LIVE na pasku stanu.
 *  - Gdy brak aktywnej relacji → "Brak aktywnej relacji" + powrót na stronę główną.
 */
import { fetchLiveMatch } from "@/lib/cms-live";

const live = await fetchLiveMatch();
const isLive = Boolean(
  live?.enabled && (live?.state === "live" || live?.state === "ht" || live?.state === "live2"),
);
const isPre = Boolean(live?.enabled && live?.state === "pre");
const showWidget = isLive || isPre;

function stateLabel(state: string | undefined): string {
  if (state === "ht") return "Przerwa";
  if (state === "live2") return "2. połowa";
  if (state === "live") return "1. połowa";
  if (state === "pre") return "Przed meczem";
  return "Koniec";
}

function fmtKickoff(iso: string | undefined): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleTimeString("pl-PL", { hour: "2-digit", minute: "2-digit", timeZone: "Europe/Warsaw" });
}
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f2a1c" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{showWidget ? "🔴 LIVE — relacja na żywo · WKS Wierzbice" : "Relacja · WKS Wierzbice"}</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="cache-control" content="no-store, no-transform" />

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: #0a1812;
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
        min-height: 100vh;
      }
      body {
        background: radial-gradient(1200px 800px at 50% 0%, rgba(22, 101, 52, 0.45), #0a1812 60%);
        padding: env(safe-area-inset-top) 0 env(safe-area-inset-bottom) 0;
      }
      .container {
        max-width: 880px;
        margin: 0 auto;
        padding: 16px;
      }
      .top-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 0 14px;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.10);
        color: #fff;
        text-decoration: none;
        font-size: 20px;
      }
      .top-title {
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.72);
      }

      .scoreboard {
        background: linear-gradient(160deg, rgba(22, 101, 52, 0.55) 0%, rgba(15, 42, 28, 0.95) 100%);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 22px;
        padding: 22px 18px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
      }

      .live-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 12px;
        background: rgba(220, 38, 38, 0.18);
        border: 1px solid rgba(220, 38, 38, 0.45);
        border-radius: 99px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .live-pill .dot {
        width: 8px; height: 8px;
        border-radius: 99px;
        background: #ef4444;
        box-shadow: 0 0 0 5px rgba(239, 68, 68, 0.18);
        animation: pulse 1.5s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.2); opacity: 0.55; }
      }

      .competition {
        margin-top: 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.62);
      }

      .teams {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 10px;
        align-items: center;
      }
      .team {
        font-size: clamp(13px, 4.2vw, 22px);
        font-weight: 900;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        line-height: 1.15;
        word-break: break-word;
        overflow-wrap: anywhere;
      }
      .team.home { text-align: right; }
      .team.away { text-align: left; }
      .score {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .score-num {
        font-size: clamp(38px, 12vw, 72px);
        font-weight: 900;
        line-height: 0.9;
        font-variant-numeric: tabular-nums;
        color: #fff;
      }

      .clock-block {
        margin-top: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .clock-state {
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.62);
        font-weight: 800;
      }
      .clock-time {
        font-size: clamp(28px, 8vw, 44px);
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        color: #fff;
      }

      .pre-info {
        margin-top: 14px;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.85);
        text-align: center;
      }
      .pre-info strong {
        font-weight: 800;
        color: #fff;
      }

      .events-section {
        margin-top: 22px;
      }
      .events-title {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 10px;
        padding: 0 4px;
      }
      .event-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .event-row {
        display: grid;
        grid-template-columns: 44px auto 1fr;
        gap: 10px;
        align-items: center;
        padding: 12px 14px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
      }
      .event-row.home {
        border-left: 3px solid #22c55e;
      }
      .event-row.away {
        border-right: 3px solid #ef4444;
        text-align: right;
        grid-template-columns: 1fr auto 44px;
      }
      .event-minute {
        font-size: 14px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.5);
        font-variant-numeric: tabular-nums;
      }
      .event-icon { font-size: 18px; }
      .event-text {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.92);
        line-height: 1.35;
        word-break: break-word;
        overflow-wrap: anywhere;
      }

      .empty {
        text-align: center;
        padding: 40px 20px;
        color: rgba(255, 255, 255, 0.5);
        font-size: 14px;
      }

      .no-live {
        max-width: 460px;
        margin: 60px auto 0;
        text-align: center;
        padding: 32px 22px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 22px;
      }
      .no-live h1 {
        font-size: 22px;
        font-weight: 900;
        margin: 8px 0 12px;
        letter-spacing: -0.01em;
      }
      .no-live p { color: rgba(255, 255, 255, 0.72); line-height: 1.5; margin: 0 0 22px; }
      .no-live a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 22px;
        background: linear-gradient(135deg, #166534 0%, #14532d 100%);
        color: #fff;
        border-radius: 14px;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(22, 101, 52, 0.4);
      }

      .reconnect {
        position: fixed;
        bottom: 18px; right: 18px;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.45);
        background: rgba(0, 0, 0, 0.35);
        padding: 6px 12px;
        border-radius: 99px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        opacity: 0;
        transition: opacity 0.2s;
      }
      .reconnect.visible { opacity: 1; }
    </style>
  </head>

  <body>
    <main class="container" id="live-root" data-initial-state={JSON.stringify(live ?? null)}>
      <div class="top-bar">
        <a class="back-link" href="/" aria-label="Wróć na stronę główną">←</a>
        <div>
          <div class="top-title">Relacja na żywo</div>
        </div>
      </div>

      {showWidget ? (
        <>
        <article class="scoreboard">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;">
            <div class="live-pill">
              <span class="dot"></span>
              <span data-live-state-pill>{stateLabel(live?.state)}</span>
            </div>
            <div class="competition" data-live-competition>
              {live?.competitionLabel ?? ""}
            </div>
          </div>

          <div class="teams" style="margin-top:18px;">
            <div class="team home" data-live-home>{live?.homeLabel ?? "WKS Wierzbice"}</div>
            <div class="score">
              <span class="score-num" data-live-score-home>{live?.scoreHome ?? 0}</span>
              <span class="score-num" style="color:rgba(255,255,255,0.4); font-weight:300;">:</span>
              <span class="score-num" data-live-score-away>{live?.scoreAway ?? 0}</span>
            </div>
            <div class="team away" data-live-away>{live?.awayLabel ?? "—"}</div>
          </div>

          <div class="clock-block" data-live-clock-block style={isPre ? "display:none" : ""}>
            <div class="clock-state" data-live-state-clock>{stateLabel(live?.state)}</div>
            <div class="clock-time" data-live-time>{live?.clock?.time ?? "--:--"}</div>
          </div>

          {isPre && (
            <div class="pre-info" data-live-pre>
              {(() => {
                const hhmm = fmtKickoff(live?.kickoffPlanned);
                return hhmm ? (
                  <>Mecz rozpoczyna się o <strong>{hhmm}</strong>.</>
                ) : (
                  <>Mecz wkrótce się rozpocznie.</>
                );
              })()}
            </div>
          )}
        </article>

        <section class="events-section">
          <div class="events-title">Zdarzenia</div>
          <ul class="event-list" data-live-events>
            {(live?.events ?? []).length === 0 ? (
              <li class="empty">Jeszcze brak zdarzeń.</li>
            ) : (
              (live?.events ?? [])
                .slice()
                .sort((a, b) => ((a.minute ?? 9999) - (b.minute ?? 9999)))
                .map((e) => {
                  const icon = e.type === "goal" ? "⚽" : e.type === "card" ? (String(e.text || "").toLowerCase().includes("czerwona") ? "🟥" : "🟨") : e.type === "sub" ? "🔁" : "ℹ️";
                  const sideCls = e.side === "home" ? "home" : e.side === "away" ? "away" : "";
                  return (
                    <li class={`event-row ${sideCls}`}>
                      <span class="event-minute">{typeof e.minute === "number" ? `${e.minute}'` : "—"}</span>
                      <span class="event-icon">{icon}</span>
                      <span class="event-text">{e.text}</span>
                    </li>
                  );
                })
            )}
          </ul>
        </section>
        </>
      ) : (
        <div class="no-live">
          <div style="font-size:36px; margin-bottom:10px;">⚪</div>
          <h1>Brak aktywnej relacji</h1>
          <p>W tej chwili nie ma transmisji na żywo. Sprawdź harmonogram nadchodzących meczów na stronie głównej.</p>
          <a href="/">← Wróć na stronę główną</a>
        </div>
      )}
    </main>

    <div class="reconnect" id="live-reconnect" aria-hidden="true">⏳ ponowne łączenie…</div>

    <script is:inline>
      // ── Real-time client ────────────────────────────────────────────────────
      // Łączy się z SSE (/wks-live-match/stream) i dodatkowo poll co 3s jako
      // backup. Aktualizuje DOM imperatywnie. Bez frameworków, ~150 linii.

      const root = document.getElementById("live-root");
      if (root) {
        const $home = root.querySelector("[data-live-home]");
        const $away = root.querySelector("[data-live-away]");
        const $sh = root.querySelector("[data-live-score-home]");
        const $sa = root.querySelector("[data-live-score-away]");
        const $clockBlock = root.querySelector("[data-live-clock-block]");
        const $statePill = root.querySelector("[data-live-state-pill]");
        const $stateClock = root.querySelector("[data-live-state-clock]");
        const $time = root.querySelector("[data-live-time]");
        const $events = root.querySelector("[data-live-events]");
        const $competition = root.querySelector("[data-live-competition]");
        const $reconnect = document.getElementById("live-reconnect");

        let live = null;
        try { live = JSON.parse(root.getAttribute("data-initial-state") || "null"); } catch {}
        let tickerHandle = null;

        const stateLabel = (s) => {
          if (s === "ht") return "Przerwa";
          if (s === "live2") return "2. połowa";
          if (s === "live") return "1. połowa";
          if (s === "pre") return "Przed meczem";
          return "Koniec";
        };

        const pad = (n) => String(n).padStart(2, "0");
        const fmtMmss = (sec) => {
          const s = Math.max(0, Math.trunc(sec || 0));
          return `${pad(Math.floor(s / 60))}:${pad(s % 60)}`;
        };
        const parseMs = (iso) => {
          if (!iso) return null;
          const t = new Date(iso).getTime();
          return Number.isFinite(t) ? t : null;
        };

        // Kanoniczny zegar: HT=45'+addedTime1, FT=90'+addedTime2; live/live2 — real time.
        const computeClock = (data) => {
          if (!data) return "--:--";
          const status = data.state;
          const a1 = Math.max(0, Math.trunc(Number(data.addedTime1) || 0));
          const a2 = Math.max(0, Math.trunc(Number(data.addedTime2) || 0));
          if (status === "ht") return `${pad(45 + a1)}:00`;
          if (status === "ft") return `${pad(90 + a2)}:00`;
          if (status === "pre") return "00:00";
          const kickoff = parseMs(data.kickoffReal);
          if (!kickoff) return "--:--";
          const pause = parseMs(data.pauseAt);
          const resume = parseMs(data.resumeAt);
          const now = Date.now();
          if (status === "live") {
            const end = pause && (!resume || resume < pause) ? pause : now;
            return fmtMmss((end - kickoff) / 1000);
          }
          if (status === "live2") {
            if (!resume) return fmtMmss((now - kickoff) / 1000);
            const end = pause && pause > resume ? pause : now;
            return fmtMmss(45 * 60 + (end - resume) / 1000);
          }
          return "--:--";
        };

        const iconFor = (e) => {
          const t = String(e?.type || "info");
          if (t === "goal") return "⚽";
          if (t === "card") return String(e?.text || "").toLowerCase().includes("czerwona") ? "🟥" : "🟨";
          if (t === "sub") return "🔁";
          return "ℹ️";
        };

        const renderEvents = (events) => {
          if (!$events) return;
          const list = Array.isArray(events) ? events.slice() : [];
          list.sort((a, b) => ((typeof a?.minute === "number" ? a.minute : 9999) - (typeof b?.minute === "number" ? b.minute : 9999)));
          $events.innerHTML = "";
          if (list.length === 0) {
            const li = document.createElement("li");
            li.className = "empty";
            li.textContent = "Jeszcze brak zdarzeń.";
            $events.appendChild(li);
            return;
          }
          for (const e of list) {
            const li = document.createElement("li");
            const sideCls = e.side === "home" ? "home" : e.side === "away" ? "away" : "";
            li.className = `event-row ${sideCls}`;
            const min = document.createElement("span");
            min.className = "event-minute";
            min.textContent = typeof e.minute === "number" ? `${e.minute}'` : "—";
            const ico = document.createElement("span");
            ico.className = "event-icon";
            ico.textContent = iconFor(e);
            const txt = document.createElement("span");
            txt.className = "event-text";
            txt.textContent = String(e.text || "");
            li.appendChild(min);
            li.appendChild(ico);
            li.appendChild(txt);
            $events.appendChild(li);
          }
        };

        // KRYTYCZNE: nie używamy window.location.reload() przy zmianie stanu.
        // Wcześniej powodowało nieskończoną pętlę (poll → enabled=false → reload →
        // SSR pokazuje "Brak relacji" → poll → reload → ...). Zamiast tego
        // przełączamy widoki inline: gdy aktywne pokazujemy scoreboard,
        // gdy nieaktywne pokazujemy overlay "Mecz zakończony / Brak relacji".
        const $scoreboard = root.querySelector(".scoreboard");
        const $eventsSection = root.querySelector(".events-section");
        // UWAGA: re-query za każdym razem zamiast zapamiętanej referencji,
        // bo overlay może być wstrzyknięty dynamicznie (gdy SSR renderował scoreboard).
        const findOverlay = () => root.querySelector(".no-live");

        const showInactive = () => {
          if ($scoreboard) $scoreboard.style.display = "none";
          if ($eventsSection) $eventsSection.style.display = "none";
          let overlay = findOverlay();
          if (overlay) {
            overlay.style.display = "";
          } else {
            overlay = document.createElement("div");
            overlay.className = "no-live";
            overlay.innerHTML = `
              <div style="font-size:36px; margin-bottom:10px;">🏁</div>
              <h1>Mecz zakończony</h1>
              <p>Relacja na żywo została zakończona. Wynik i podsumowanie pojawią się wkrótce w aktualnościach.</p>
              <a href="/">← Wróć na stronę główną</a>
            `;
            root.appendChild(overlay);
          }
        };
        const showActive = () => {
          if ($scoreboard) $scoreboard.style.display = "";
          if ($eventsSection) $eventsSection.style.display = "";
          const overlay = findOverlay();
          if (overlay) overlay.style.display = "none";
        };

        // SSE z CMS-a publikuje raw `doc` (pole `status`), polling z /wks-live-match
        // przechodzi przez fetchLiveMatch() i ma `state`. Bez normalize SSE message
        // miał `state=undefined` → isActive=false → overlay "Mecz zakończony" wyciekał.
        const normalizeFromAnySource = (raw) => {
          if (!raw) return null;
          return {
            ...raw,
            state: raw.state || raw.status,
            enabled: Boolean(raw.enabled),
          };
        };

        const update = (rawData) => {
          const data = normalizeFromAnySource(rawData);
          if (!data) return;
          const isActive = Boolean(
            data.enabled && (data.state === "live" || data.state === "ht" || data.state === "live2" || data.state === "pre"),
          );
          if (!isActive) {
            live = null;
            showInactive();
            return;
          }
          // Stan przeszedł z nieaktywnego na aktywny → upewnij się że scoreboard widoczny.
          // Pierwsze wejście z SSR=active po prostu wykonuje aktualizację pól.
          if ($scoreboard && getComputedStyle($scoreboard).display === "none") showActive();
          live = data;
          if ($home) $home.textContent = data.homeLabel || "WKS Wierzbice";
          if ($away) $away.textContent = data.awayLabel || "—";
          if ($sh) $sh.textContent = String(data.scoreHome ?? 0);
          if ($sa) $sa.textContent = String(data.scoreAway ?? 0);
          if ($competition) $competition.textContent = data.competitionLabel || "";
          if ($statePill) $statePill.textContent = stateLabel(data.state);
          if ($stateClock) $stateClock.textContent = stateLabel(data.state);
          if ($clockBlock) $clockBlock.style.display = data.state === "pre" ? "none" : "";
          if ($time) $time.textContent = computeClock(data);
          renderEvents(data.events);
        };

        // Tykanie zegara co sekundę (lokalnie, bez czekania na SSE).
        if (tickerHandle) clearInterval(tickerHandle);
        tickerHandle = setInterval(() => {
          if (!live) return;
          if (live.state === "live" || live.state === "live2") {
            if ($time) $time.textContent = computeClock(live);
          }
        }, 500);

        // Polling fallback co 3s (jeśli SSE nie żyje, dane i tak płyną).
        let pollHandle = null;
        const startPolling = () => {
          if (pollHandle) return;
          const tick = async () => {
            try {
              // Cache-bust query param + Cache-Control no-store.
              const r = await fetch(`/wks-live-match?t=${Date.now()}`, { cache: "no-store" });
              if (!r.ok) return;
              const data = await r.json();
              update(data);
            } catch {}
          };
          tick();
          pollHandle = setInterval(tick, 3000);
        };
        const stopPolling = () => {
          if (!pollHandle) return;
          clearInterval(pollHandle);
          pollHandle = null;
        };

        // SSE — real-time push. Reconnect on error po 2s.
        let es = null;
        let sseAlive = false;
        const connectSSE = () => {
          try {
            es = new EventSource("/wks-live-match/stream");
            es.onmessage = (ev) => {
              sseAlive = true;
              if ($reconnect) $reconnect.classList.remove("visible");
              try {
                const data = JSON.parse(ev.data);
                update(data);
              } catch {}
            };
            es.onopen = () => {
              sseAlive = true;
              if ($reconnect) $reconnect.classList.remove("visible");
            };
            es.onerror = () => {
              sseAlive = false;
              if ($reconnect) $reconnect.classList.add("visible");
              try { es && es.close(); } catch {}
              es = null;
              setTimeout(connectSSE, 2000);
            };
          } catch {
            setTimeout(connectSSE, 2000);
          }
        };

        connectSSE();
        startPolling(); // zawsze aktywny — drobny narzut, ale gwarantuje świeżość gdy SSE pada
      }
    </script>
  </body>
</html>
