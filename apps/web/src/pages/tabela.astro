---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import LeagueStandingsTable from "@/components/LeagueStandingsTable.astro";
import { SITE, STATS } from "@/config/site";
import { fetchSeason } from "@/lib/cms-season";

const season = await fetchSeason();
const standings = season.standings;

const formatFetchedAt = (iso: string | null) => {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleString("pl-PL", {
    day: "2-digit",
    month: "long",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
};

const fetchedAtLabel = formatFetchedAt(season.fetchedAt);
---

<BaseLayout
  title="Tabela ligowa"
  description={`Aktualna tabela rozgrywek seniorów – ${SITE.shortName}. Dane z 90minut.pl.`}
>
  <PageHeader
    kicker="Seniorzy"
    title="Tabela ligowa"
    description={`Pełna tabela ${season.season}. Terminarz i wyniki meczów znajdziesz w zakładce Terminarz.`}
  />

  <section class="section">
    <div class="container mx-auto max-w-4xl">
      <LeagueStandingsTable standings={standings} seasonLabel={season.season} />
      {standings.length === 0 && (
        <p class="text-center text-slate-600">Brak danych tabeli — spróbuj ponownie później.</p>
      )}
    </div>
  </section>

  <section class="section bg-slate-50">
    <div class="container mx-auto max-w-3xl text-center">
      <h3 class="text-xl font-display uppercase tracking-tight">Powiązane</h3>
      <div class="mt-6 flex flex-wrap gap-3 justify-center">
        <a href="/terminarz" class="btn-primary">Terminarz i wyniki meczów</a>
        <a href="/" class="btn-outline text-brand-primary border-brand-primary hover:bg-brand-primary hover:text-white">
          Strona główna
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container mx-auto max-w-3xl text-center">
      <h3 class="text-xl">Źródło danych</h3>
      <p class="mt-3 text-slate-600">
        Tabela synchronizowana jest automatycznie z serwisu
        <a
          href={STATS.ninetyMinutLeague}
          target="_blank"
          rel="noopener"
          class="underline hover:text-brand-primary"
        >
          90minut.pl
        </a>
        {fetchedAtLabel && (
          <>
            {" "}
            – ostatnia aktualizacja: <strong>{fetchedAtLabel}</strong>
          </>
        )}.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 justify-center">
        <a
          href={STATS.ninetyMinutMatches}
          target="_blank"
          rel="noopener"
          class="btn-outline text-brand-primary border-brand-primary hover:bg-brand-primary hover:text-white"
        >
          Mecze drużyny
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
