---
interface Props {
  href: string;
  name: string;
  category: string;
  league?: string;
  coach: string;
  photo?: string;
}

const { href, name, category, league, coach, photo } = Astro.props;
---

<a href={href} class="card group block">
  <div class="aspect-[16/9] bg-slate-200 overflow-hidden">
    {
      photo ? (
        <img
          src={photo}
          alt={`Drużyna ${name}`}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-brand-ink to-brand-primary-dark text-white font-display text-2xl uppercase">
          {category}
        </div>
      )
    }
  </div>
  <div class="p-5">
    <div class="text-xs uppercase tracking-widest text-brand-primary font-display">
      {category}
    </div>
    <h3 class="text-2xl font-display uppercase mt-1 group-hover:text-brand-primary transition-colors">
      {name}
    </h3>
    <dl class="mt-3 text-sm text-slate-600 space-y-1">
      {
        league && (
          <div class="flex gap-2">
            <dt class="font-medium text-slate-700">Liga:</dt>
            <dd>{league}</dd>
          </div>
        )
      }
      <div class="flex gap-2">
        <dt class="font-medium text-slate-700">Trener:</dt>
        <dd>{coach}</dd>
      </div>
    </dl>
  </div>
</a>
