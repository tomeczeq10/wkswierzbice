---
import { SITE, SOCIAL } from "@/config/site";

interface Result {
  outcome: "win" | "draw" | "loss";
  scoreLabel: string;
}
interface Match {
  round: number;
  date: string | null;
  time: string | null;
  dateRaw: string | null;
  venue: "home" | "away";
  opponent: string;
  result?: Result | null;
}

interface Props {
  nextMatch?: Match | null;
  lastMatch?: Match | null;
  position?: number | null;
  points?: number | null;
}

const { nextMatch, lastMatch, position, points } = Astro.props;

const isoDate = nextMatch?.date
  ? `${nextMatch.date}T${nextMatch.time ?? "12:00"}:00+02:00`
  : null;

const PL_WEEKDAYS = ["niedziela", "poniedziałek", "wtorek", "środa", "czwartek", "piątek", "sobota"];
const PL_MONTHS = ["stycznia", "lutego", "marca", "kwietnia", "maja", "czerwca", "lipca", "sierpnia", "września", "października", "listopada", "grudnia"];
const formatLongDate = (dateStr: string | null, time: string | null) => {
  if (!dateStr) return null;
  const d = new Date(`${dateStr}T${time ?? "12:00"}:00+02:00`);
  if (Number.isNaN(d.getTime())) return null;
  const weekday = PL_WEEKDAYS[d.getDay()];
  const day = d.getDate();
  const month = PL_MONTHS[d.getMonth()];
  return time ? `${weekday}, ${day} ${month} · ${time}` : `${weekday}, ${day} ${month}`;
};

const longDate = nextMatch ? formatLongDate(nextMatch.date, nextMatch.time) : null;

const outcomeColor = {
  win: "text-emerald-300",
  draw: "text-amber-300",
  loss: "text-rose-300",
};
---

<section class="relative h-[calc(100vh-72px)] min-h-[640px] flex flex-col overflow-hidden bg-black text-white isolate">

  {/* Animated background */}
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-black via-brand-primary-dark to-black"></div>
    <div class="marka-orbA absolute -top-40 -left-40 w-[700px] h-[700px] rounded-full bg-brand-primary/30 blur-3xl"></div>
    <div class="marka-orbB absolute -bottom-40 -right-40 w-[700px] h-[700px] rounded-full bg-brand-secondary/20 blur-3xl"></div>
    <img
      src="/herb-wks.png"
      alt=""
      aria-hidden="true"
      class="absolute right-[-10%] top-1/2 -translate-y-1/2 h-[110%] object-contain opacity-[0.06] mix-blend-luminosity"
    />
  </div>

  {/* TOP — match day badge */}
  <div class="container mx-auto px-4 pt-8 lg:pt-12 flex items-center justify-between gap-4">
    {nextMatch ? (
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-secondary text-white text-[10px] sm:text-[11px] uppercase tracking-[0.3em] font-display shadow-2xl">
        <span class="w-1.5 h-1.5 rounded-full bg-white marka-pulse"></span>
        Match&nbsp;Day · kolejka {nextMatch.round}
      </div>
    ) : (
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-white text-[11px] uppercase tracking-[0.3em] font-display backdrop-blur">
        Sezon {SITE.league.split(" ")[2] ?? "2025/2026"}
      </div>
    )}
    <div class="hidden sm:flex items-center gap-2 text-[11px] uppercase tracking-[0.3em] text-white/40 font-display">
      <span class="w-8 h-px bg-white/20"></span>
      Wierzbice · Tarnopolska 21
    </div>
  </div>

  {/* CENTER — gigant typography */}
  <div class="flex-1 container mx-auto px-4 grid lg:grid-cols-[1.2fr,auto] items-center gap-8 lg:gap-12 py-10">

    <div>
      <div class="font-display uppercase text-white/60 text-sm tracking-[0.4em] mb-3 lg:mb-4 marka-fadeup">
        Wiejski Klub Sportowy
      </div>
      <h1 class="font-display uppercase tracking-[-0.02em] leading-[0.85] text-[20vw] sm:text-[16vw] lg:text-[11vw] xl:text-[10rem] marka-fadeup" style="animation-delay:.1s">
        Wierzbice
      </h1>
      <div class="mt-4 lg:mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/70 marka-fadeup" style="animation-delay:.2s">
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-secondary" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {position ? `${position}. miejsce` : "Wicelider"} · {points ?? 50} pkt
        </span>
        <span class="hidden sm:inline">Zielono-biało-czerwoni z gminy Kobierzyce</span>
      </div>

      <div class="mt-7 lg:mt-9 flex flex-wrap gap-3 marka-fadeup" style="animation-delay:.3s">
        <a href="/terminarz" class="btn-primary">Terminarz meczów</a>
        <a href="/nabory" class="btn-outline text-white border-white hover:bg-white hover:text-black">Zapisz dziecko</a>
        <a href={SOCIAL.facebook} target="_blank" rel="noopener" class="btn-outline text-white border-white/30 hover:bg-white/10">
          Facebook ({SOCIAL.facebookFollowers.toLocaleString("pl-PL")})
        </a>
      </div>
    </div>

    {/* RIGHT — match card */}
    {nextMatch && (
      <div class="hidden lg:block w-[26rem] marka-fadeup" style="animation-delay:.4s">
        <div class="rounded-2xl border border-white/15 bg-black/40 backdrop-blur-md overflow-hidden shadow-[0_30px_80px_-10px_rgba(0,0,0,0.6)]">
          <div class="px-6 py-3 bg-brand-secondary/95 text-[10px] uppercase tracking-[0.3em] font-display flex items-center justify-between">
            <span>Najbliższy mecz</span>
            <span class="text-white/80">{nextMatch.venue === "home" ? "u siebie" : "wyjazd"}</span>
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between gap-3 mb-5">
              <div class="text-right flex-1">
                <div class="text-[10px] uppercase tracking-widest text-white/40 font-display">Gosp.</div>
                <div class="font-display text-lg uppercase leading-tight">
                  {nextMatch.venue === "home" ? "WKS" : nextMatch.opponent.split(" ").slice(0,2).join(" ")}
                </div>
              </div>
              <div class="font-display text-3xl text-brand-secondary px-2">vs</div>
              <div class="text-left flex-1">
                <div class="text-[10px] uppercase tracking-widest text-white/40 font-display">Gość</div>
                <div class="font-display text-lg uppercase leading-tight">
                  {nextMatch.venue === "home" ? nextMatch.opponent.split(" ").slice(0,2).join(" ") : "WKS"}
                </div>
              </div>
            </div>

            {isoDate ? (
              <div class="flex gap-2 justify-center" id="marka-cd">
                {(["days", "hours", "minutes", "seconds"] as const).map((unit) => (
                  <div class="flex flex-col items-center">
                    <div
                      id={`mcd-${unit}`}
                      class="w-14 h-14 bg-white/5 border border-white/10 rounded-md flex items-center justify-center font-display text-2xl"
                    >
                      --
                    </div>
                    <div class="mt-1 text-[9px] uppercase tracking-widest text-white/50">
                      {unit === "days" ? "dni" : unit === "hours" ? "h" : unit === "minutes" ? "min" : "sek"}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="text-center text-sm uppercase tracking-widest font-display text-white/50">
                Termin do ustalenia
              </div>
            )}

            {longDate && (
              <div class="mt-5 pt-4 border-t border-white/10 text-center text-xs text-white/60">
                {longDate}
              </div>
            )}

            {lastMatch && (
              <div class="mt-4 pt-4 border-t border-white/10 flex items-center gap-3 text-xs">
                <span class="text-[10px] uppercase tracking-widest text-white/40 font-display shrink-0">Ostatni</span>
                <span class={`font-display text-base ${outcomeColor[lastMatch.result?.outcome ?? "draw"]}`}>
                  {lastMatch.result?.scoreLabel ?? "-:-"}
                </span>
                <span class="text-white/70 truncate">{lastMatch.opponent}</span>
              </div>
            )}
          </div>
        </div>
      </div>
    )}

  </div>

  {/* Diagonal bottom divider */}
  <div class="absolute bottom-0 left-0 right-0 h-24 lg:h-32 bg-white" style="clip-path: polygon(0 100%, 100% 30%, 100% 100%);"></div>
</section>

{isoDate && (
  <script define:vars={{ isoDate }}>
    const target = new Date(isoDate).getTime();
    const pad = (n) => String(Math.max(0, n)).padStart(2, "0");
    function tick() {
      const diff = target - Date.now();
      if (diff <= 0) { document.getElementById("marka-cd")?.remove(); return; }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      const el = (id) => document.getElementById(id);
      el("mcd-days") && (el("mcd-days").textContent = pad(d));
      el("mcd-hours") && (el("mcd-hours").textContent = pad(h));
      el("mcd-minutes") && (el("mcd-minutes").textContent = pad(m));
      el("mcd-seconds") && (el("mcd-seconds").textContent = pad(s));
    }
    tick();
    setInterval(tick, 1000);
  </script>
)}
