---
import {
  TEMPLATES,
  DEFAULT_TEMPLATE,
  TEMPLATE_STORAGE_KEY,
} from "./registry";
---

<div
  id="tpl-switcher"
  class="fixed bottom-4 right-4 z-[60] print:hidden"
  data-collapsed="true"
>
  <!-- Collapsed pill -->
  <button
    id="tpl-toggle"
    type="button"
    class="group flex items-center gap-2 rounded-full bg-brand-ink/95 backdrop-blur text-white pl-3 pr-4 py-2.5 shadow-2xl border border-white/15 hover:bg-brand-ink transition-colors"
    aria-expanded="false"
    aria-controls="tpl-panel"
    aria-label="Zmień wygląd strony"
  >
    <svg
      class="w-4 h-4 text-brand-secondary group-hover:rotate-12 transition-transform"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="13.5" cy="6.5" r=".5" />
      <circle cx="17.5" cy="10.5" r=".5" />
      <circle cx="8.5" cy="7.5" r=".5" />
      <circle cx="6.5" cy="12.5" r=".5" />
      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125 0-.937.722-1.688 1.648-1.688h1.938c3.094 0 5.641-2.547 5.641-5.594C22 6.493 17.5 2 12 2z" />
    </svg>
    <span class="font-display uppercase tracking-widest text-[11px]">Szablon</span>
    <span
      id="tpl-current"
      class="font-display text-xs text-brand-secondary border-l border-white/20 pl-2 ml-1"
      >Klasyk</span
    >
  </button>

  <!-- Expanded panel -->
  <div
    id="tpl-panel"
    role="dialog"
    aria-label="Wybór szablonu strony"
    class="hidden absolute bottom-full right-0 mb-2 w-[20rem] sm:w-[22rem] bg-white rounded-xl shadow-2xl border border-slate-200 overflow-hidden"
  >
    <div class="px-4 py-3 bg-brand-ink text-white">
      <div class="font-display uppercase tracking-widest text-[11px] text-brand-secondary">
        Demo dla zarządu
      </div>
      <div class="text-sm font-display uppercase mt-0.5">Wybierz wygląd strony</div>
    </div>

    <ul class="divide-y divide-slate-100" role="radiogroup">
      {
        TEMPLATES.map((tpl) => (
          <li>
            <button
              type="button"
              class="tpl-option w-full text-left px-4 py-3 hover:bg-slate-50 flex gap-3 items-start transition-colors"
              data-tpl={tpl.id}
              role="radio"
              aria-checked="false"
            >
              <span
                class="mt-1 inline-block w-3 h-3 rounded-full shrink-0 border border-white shadow"
                style={`background-color: ${tpl.swatch}`}
              />
              <span class="flex-1 min-w-0">
                <span class="flex items-center gap-2">
                  <span class="font-display uppercase tracking-tight text-brand-ink text-sm">
                    {tpl.name}
                  </span>
                  <span class="tpl-active-badge hidden text-[9px] uppercase tracking-widest font-display bg-brand-primary text-white px-1.5 py-0.5 rounded">
                    Aktywny
                  </span>
                </span>
                <span class="block text-xs text-slate-500 mt-1 leading-relaxed">
                  {tpl.description}
                </span>
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    <div class="px-4 py-2.5 text-[10px] uppercase tracking-widest font-display text-slate-400 bg-slate-50 border-t border-slate-100">
      Wybór zapamiętywany lokalnie · zmiana na wszystkich podstronach
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{ TEMPLATES, DEFAULT_TEMPLATE, TEMPLATE_STORAGE_KEY }}
>
  (function () {
    var root = document.documentElement;
    var wrap = document.getElementById("tpl-switcher");
    var toggle = document.getElementById("tpl-toggle");
    var panel = document.getElementById("tpl-panel");
    var currentLabel = document.getElementById("tpl-current");
    var options = document.querySelectorAll(".tpl-option");

    if (!wrap || !toggle || !panel) return;

    function syncUI(tplId) {
      var def = TEMPLATES.find(function (t) {
        return t.id === tplId;
      });
      if (def && currentLabel) currentLabel.textContent = def.short;
      options.forEach(function (opt) {
        var isActive = opt.getAttribute("data-tpl") === tplId;
        opt.setAttribute("aria-checked", isActive ? "true" : "false");
        var badge = opt.querySelector(".tpl-active-badge");
        if (badge) badge.classList.toggle("hidden", !isActive);
        if (isActive) {
          opt.classList.add("bg-brand-primary/5");
        } else {
          opt.classList.remove("bg-brand-primary/5");
        }
      });
    }

    var initialTpl =
      root.getAttribute("data-template") || DEFAULT_TEMPLATE;
    syncUI(initialTpl);

    function openPanel() {
      panel.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
      wrap.setAttribute("data-collapsed", "false");
    }
    function closePanel() {
      panel.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      wrap.setAttribute("data-collapsed", "true");
    }

    toggle.addEventListener("click", function () {
      if (panel.classList.contains("hidden")) openPanel();
      else closePanel();
    });

    document.addEventListener("click", function (e) {
      if (!wrap.contains(e.target)) closePanel();
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closePanel();
    });

    options.forEach(function (opt) {
      opt.addEventListener("click", function () {
        var id = opt.getAttribute("data-tpl");
        if (!id) return;
        try {
          localStorage.setItem(TEMPLATE_STORAGE_KEY, id);
        } catch (e) {}
        root.setAttribute("data-template", id);
        syncUI(id);
        closePanel();
      });
    });
  })();
</script>
