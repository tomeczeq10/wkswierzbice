{
  "name": "wks-cms-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo dla strony WKS Wierzbice — apps/web (Astro frontend) + apps/cms (Payload, w przygotowaniu) + packages/shared (typy)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:cms": "npm run dev --workspace=cms",
    "build": "npm run build --workspace=web",
    "build:cms": "npm run build --workspace=cms",
    "preview": "npm run preview --workspace=web",
    "sync:season": "npm run sync:season --workspace=web",
    "payload": "npm run payload --workspace=cms",
    "generate:types": "npm run generate:types --workspace=cms",
    "generate:importmap": "npm run generate:importmap --workspace=cms",
    "migrate:teams": "npx tsx apps/cms/scripts/migrate-teams.ts",
    "migrate:team-photos": "npx tsx apps/cms/scripts/migrate-team-photos.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
